---
// IndustryInsightQuiz — 5-card single-question-per-screen, auto-advance, ES+EN.
// Provokes "you're behind" recognition via percentages + dollar amounts.
// localStorage gate: jufipai_quiz_v1 — skip on revisit within 24h.
// Final card CTA opens NewsletterModal via window.jufipaiOpenNewsletter().
---

<section class="quiz-section" id="industry-insight-quiz" aria-label="Industry Insight Quiz">
  <div class="quiz-shell">

    <span class="quiz-eyebrow" id="quiz-eyebrow"
      data-en="Question 1 of 5" data-es="Pregunta 1 de 5">
      Pregunta 1 de 5
    </span>

    <!-- QUESTION CARD -->
    <div class="quiz-question" id="quiz-question">
      <h2 class="quiz-headline" id="quiz-question-text"></h2>
      <div class="quiz-options" role="radiogroup" id="quiz-options" aria-label="Answer options"></div>
    </div>

    <!-- REVEAL CARD -->
    <div class="quiz-reveal" id="quiz-reveal" hidden>
      <div class="quiz-reveal-card">
        <div class="quiz-guess" id="quiz-guess">
          <span class="quiz-mini-label" id="quiz-guess-label" data-en="YOU GUESSED" data-es="TÚ DIJISTE">TÚ DIJISTE</span>
          <p class="quiz-guess-value" id="quiz-guess-value"></p>
        </div>
        <div class="quiz-divider" aria-hidden="true"></div>
        <div class="quiz-reality" id="quiz-reality">
          <span class="quiz-mini-label quiz-mini-label--jade" data-en="REALITY" data-es="LA REALIDAD">LA REALIDAD</span>
          <p class="quiz-reality-value" id="quiz-reality-value"></p>
        </div>
      </div>
      <p class="quiz-reveal-body" id="quiz-reveal-body" aria-live="polite"></p>
      <p class="quiz-reveal-source" id="quiz-reveal-source"></p>
      <div class="quiz-progress" id="quiz-progress" aria-hidden="true"></div>
      <button type="button" class="quiz-next" id="quiz-next"
        data-en="Next" data-es="Siguiente">
        Siguiente
      </button>
    </div>

    <!-- FINAL CARD -->
    <div class="quiz-final" id="quiz-final" hidden>
      <h2 class="quiz-final-headline"
        data-en="Your industry is leaving hours and money on the table."
        data-es="Tu industria está dejando horas y dinero sobre la mesa.">
        Tu industria está dejando horas y dinero sobre la mesa.
      </h2>
      <p class="quiz-final-sub"
        data-en="We can help. Get the next system before everyone else."
        data-es="Podemos ayudarte. Recibe el próximo sistema antes que nadie.">
        Podemos ayudarte. Recibe el próximo sistema antes que nadie.
      </p>
      <button type="button" class="quiz-final-cta" id="quiz-final-cta"
        data-en="Get the next one"
        data-es="Recibirlo">
        Recibirlo
      </button>
    </div>

    <button type="button" class="quiz-skip" id="quiz-skip"
      data-en="Skip" data-es="Saltar"
      aria-label="Skip quiz">
      Saltar
    </button>
  </div>
</section>

<style>
  .quiz-section {
    padding: var(--space-2xl) var(--space-md);
    background: var(--color-papel);
    display: flex;
    justify-content: center;
  }

  .quiz-shell {
    position: relative;
    width: 100%;
    max-width: 560px;
    background: var(--color-surface);
    border: 1px solid var(--color-arena);
    border-radius: var(--radius-modal);
    padding: 3rem 1.5rem 2rem;
    box-shadow: 0 12px 32px rgba(31, 36, 33, 0.06);
  }

  @media (min-width: 768px) {
    .quiz-shell {
      padding: 3.5rem 3rem 2.5rem;
    }
  }

  .quiz-eyebrow {
    display: inline-block;
    font-family: var(--font-mono);
    font-size: 10px;
    font-weight: 600;
    letter-spacing: 1.2px;
    text-transform: uppercase;
    color: var(--color-jade-deep);
    background: var(--color-jade-soft);
    padding: 4px 10px;
    border-radius: var(--radius-pill);
    margin-bottom: 1.25rem;
  }

  .quiz-headline {
    font-family: var(--font-display);
    font-size: clamp(1.5rem, 3vw, 2rem);
    font-weight: 600;
    line-height: 1.2;
    letter-spacing: -0.015em;
    color: var(--color-carbon);
    margin: 0 0 1.25rem;
  }

  .quiz-options {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .quiz-option {
    width: 100%;
    text-align: left;
    padding: 1rem 1.25rem;
    font-family: var(--font-body);
    font-size: 1rem;
    color: var(--color-carbon);
    background: var(--color-surface);
    border: 1px solid #D8D2C2;
    border-radius: 12px;
    cursor: pointer;
    display: flex;
    align-items: center;
    gap: 0.875rem;
    box-shadow: 0 1px 2px rgba(31, 36, 33, 0.04);
    transition: border-color 180ms var(--ease-spring),
                background 180ms var(--ease-spring),
                transform 180ms var(--ease-spring),
                box-shadow 220ms var(--ease-spring);
  }

  .quiz-option:hover:not(:disabled) {
    border-color: var(--color-jade);
    background: #FFFFFF;
    transform: translateY(-2px);
    box-shadow: 0 6px 16px rgba(14, 124, 102, 0.12);
  }
  .quiz-option:hover:not(:disabled) .quiz-option-key {
    background: var(--color-jade);
    color: #FFFFFF;
  }

  .quiz-option:focus-visible {
    outline: 2px solid var(--color-jade);
    outline-offset: 3px;
  }

  .quiz-option:active:not(:disabled),
  .quiz-option.is-tapped {
    transform: translateY(0) scale(0.985);
    box-shadow: 0 1px 2px rgba(14, 124, 102, 0.20) inset;
    border-color: var(--color-jade);
  }
  .quiz-option.is-tapped .quiz-option-key {
    background: var(--color-jade);
    color: #FFFFFF;
  }

  .quiz-option-key {
    width: 2.25rem;
    height: 2.25rem;
    display: grid;
    place-items: center;
    font-family: var(--font-body);
    font-size: 0.8125rem;
    font-weight: 600;
    color: var(--color-jade-deep);
    background: var(--color-jade-soft);
    border-radius: 999px;
    flex-shrink: 0;
    transition: background 180ms var(--ease-spring), color 180ms var(--ease-spring);
  }

  .quiz-option.is-correct {
    border-color: var(--color-jade);
    background: var(--color-jade);
    color: #FFFFFF;
  }

  .quiz-option.is-correct .quiz-option-key {
    background: rgba(255, 255, 255, 0.18);
    color: #FFFFFF;
  }

  .quiz-option.is-wrong {
    opacity: 0.55;
  }

  @keyframes optionRise {
    from { opacity: 0; transform: translateY(8px); }
    to   { opacity: 1; transform: translateY(0); }
  }
  .quiz-options .quiz-option {
    animation: optionRise 220ms var(--ease-spring) both;
  }
  .quiz-options .quiz-option:nth-child(1) { animation-delay: 40ms; }
  .quiz-options .quiz-option:nth-child(2) { animation-delay: 100ms; }
  .quiz-options .quiz-option:nth-child(3) { animation-delay: 160ms; }
  @media (prefers-reduced-motion: reduce) {
    .quiz-options .quiz-option { animation: none; }
    .quiz-option:active:not(:disabled),
    .quiz-option.is-tapped { transform: none; }
  }

  .quiz-question,
  .quiz-reveal,
  .quiz-final {
    transition: opacity 200ms var(--ease-spring);
  }

  .quiz-question.is-fading,
  .quiz-reveal.is-fading,
  .quiz-final.is-fading {
    opacity: 0;
  }

  .quiz-reveal-card {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
    margin: 0 0 1.5rem;
  }
  .quiz-guess, .quiz-reality {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
    min-width: 0;
  }
  .quiz-mini-label {
    font-family: var(--font-mono);
    font-size: 10px;
    font-weight: 600;
    letter-spacing: 1.2px;
    text-transform: uppercase;
    color: var(--color-carbon-soft);
    word-break: break-word;
    overflow-wrap: anywhere;
  }
  .quiz-mini-label--jade { color: var(--color-jade-deep); }
  .quiz-guess-value {
    font-family: var(--font-display);
    font-size: 1.5rem;
    font-weight: 500;
    color: var(--color-carbon-soft);
    opacity: 0.65;
    margin: 0;
    line-height: 1.15;
    word-break: break-word;
  }
  .quiz-guess.is-nailed .quiz-guess-value {
    color: var(--color-jade-deep);
    opacity: 1;
  }
  .quiz-divider {
    height: 1px;
    background: var(--color-arena);
    width: 100%;
  }
  .quiz-reality-value {
    font-family: var(--font-mono);
    font-size: clamp(2.5rem, 9vw, 4rem);
    font-weight: 700;
    color: var(--color-jade);
    margin: 0;
    line-height: 1;
    letter-spacing: -0.02em;
    font-variant-numeric: tabular-nums;
    word-break: break-word;
  }

  .quiz-reveal-body {
    font-family: var(--font-body);
    font-size: 1.0625rem;
    line-height: 1.55;
    color: var(--color-carbon);
    margin: 0 0 1rem;
    opacity: 0;
    transition: opacity 240ms var(--ease-spring);
  }

  .quiz-reveal-source {
    font-family: var(--font-mono);
    font-size: 10px;
    line-height: 1.4;
    color: var(--color-carbon-soft);
    margin: 0 0 1.5rem;
    opacity: 0;
    transition: opacity 240ms var(--ease-spring);
  }

  .quiz-progress,
  .quiz-next {
    opacity: 0;
    transition: opacity 240ms var(--ease-spring),
                background var(--duration-base) var(--ease-spring),
                transform var(--duration-base) var(--ease-spring);
  }

  .quiz-reveal-body.is-in,
  .quiz-reveal-source.is-in,
  .quiz-progress.is-in,
  .quiz-next.is-in {
    opacity: 1;
  }

  .quiz-progress {
    display: flex;
    gap: 0.5rem;
    justify-content: center;
    margin-bottom: 1.5rem;
  }

  .quiz-dot {
    width: 8px;
    height: 8px;
    border-radius: var(--radius-pill);
    background: var(--color-arena);
    transition: background var(--duration-base) var(--ease-spring);
  }

  .quiz-dot.is-on {
    background: var(--color-jade);
  }

  .quiz-next,
  .quiz-final-cta {
    width: 100%;
    padding: 0.9rem 1.25rem;
    font-family: var(--font-body);
    font-size: 1rem;
    font-weight: 600;
    color: #FFFFFF;
    background: var(--color-jade);
    border: none;
    border-radius: 12px;
    cursor: pointer;
    transition: background var(--duration-base) var(--ease-spring),
                transform var(--duration-base) var(--ease-spring),
                opacity 240ms var(--ease-spring);
  }

  .quiz-next:hover,
  .quiz-final-cta:hover {
    background: var(--color-jade-deep);
    transform: translateY(-1px);
  }

  .quiz-next:focus-visible,
  .quiz-final-cta:focus-visible {
    outline: 2px solid var(--color-jade);
    outline-offset: 2px;
  }

  .quiz-final-headline {
    font-family: var(--font-display);
    font-size: clamp(1.5rem, 3vw, 1.875rem);
    font-weight: 600;
    line-height: 1.2;
    color: var(--color-carbon);
    margin: 0 0 0.75rem;
  }

  .quiz-final-sub {
    font-family: var(--font-body);
    font-size: 1rem;
    line-height: 1.55;
    color: var(--color-carbon-soft);
    margin: 0 0 1.5rem;
  }

  .quiz-skip {
    position: absolute;
    top: 1rem;
    right: 1rem;
    background: transparent;
    border: none;
    color: var(--color-carbon-soft);
    font-family: var(--font-body);
    font-size: 0.8125rem;
    cursor: pointer;
    padding: 0.25rem 0.5rem;
    text-decoration: underline;
    text-decoration-color: transparent;
    transition: text-decoration-color var(--duration-base) var(--ease-spring),
                color var(--duration-base) var(--ease-spring);
  }

  .quiz-skip:hover {
    color: var(--color-carbon);
    text-decoration-color: var(--color-carbon-soft);
  }

  @media (prefers-reduced-motion: reduce) {
    .quiz-question,
    .quiz-reveal,
    .quiz-final,
    .quiz-option,
    .quiz-next,
    .quiz-final-cta,
    .quiz-reveal-body,
    .quiz-reveal-source,
    .quiz-progress {
      transition: none !important;
      animation: none !important;
    }
    .quiz-reveal-body,
    .quiz-reveal-source,
    .quiz-progress,
    .quiz-next { opacity: 1; }
  }
</style>

<script>
  // IndustryInsightQuiz — vanilla TS, no dependencies.
  const STORAGE_KEY = 'jufipai_quiz_v1';
  const REVISIT_HOURS = 24;
  const AUTO_ADVANCE_MS = 12000;
  const COUNTER_DURATION_MS = 1200;
  const REVEAL_DELAY_MS = 320;

  type CounterShape = 'count' | 'currency' | 'percent' | 'hours' | 'multiplier';

  type QuestionData = {
    eyebrowEn: string;
    eyebrowEs: string;
    questionEn: string;
    questionEs: string;
    options: { en: string; es: string; value: number }[];
    correctIdx: number;
    barShape: CounterShape;
    answerEn: string;
    answerEs: string;
    bodyEn: string;
    bodyEs: string;
    sourceEn: string;
    sourceEs: string;
  };

  const QUESTIONS: QuestionData[] = [
    {
      eyebrowEn: 'Question 1 of 5 — Real Estate',
      eyebrowEs: 'Pregunta 1 de 5 — Bienes Raíces',
      questionEn: "What share of US real estate agents pay for tech tools they haven't fully mastered?",
