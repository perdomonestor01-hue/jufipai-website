      sourceEs: 'Fuente: Buildium 2026 Property Management Industry Report',
    },
    {
      eyebrowEn: 'Question 5 of 5 — Small Business',
      eyebrowEs: 'Pregunta 5 de 5 — Pequeña Empresa',
      questionEn: 'What share of small businesses take more than 5 days to respond to a lead inquiry?',
      questionEs: '¿Qué porcentaje de las pequeñas empresas tarda más de 5 días en responder a una solicitud de cliente?',
      options: [
        { en: '20%', es: '20%', value: 20 },
        { en: '38%', es: '38%', value: 38 },
        { en: '55%', es: '55%', value: 55 },
      ],
      correctIdx: 2,
      barShape: 'percent',
      answerEn: '55%.',
      answerEs: '55%.',
      bodyEn: 'The first company to respond wins 78% of the time. Yet 55% of small businesses take more than 5 days to reply.',
      bodyEs: 'La primera empresa en responder gana el 78% de las veces. Sin embargo, el 55% de las pequeñas empresas tarda más de 5 días.',
      sourceEn: 'Source: LeanData, cited Vendasta August 2025',
      sourceEs: 'Fuente: LeanData, citado por Vendasta agosto 2025',
    },
  ];

  type QuizPhase = 'question' | 'reveal' | 'final';

  type QuizState = {
    idx: number;
    phase: QuizPhase;
    selected: number | null;
  };

  function getLang(): 'es' | 'en' {
    return document.documentElement.lang === 'es' ? 'es' : 'en';
  }

  function prefersReducedMotion(): boolean {
    return window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  }

  function shouldSkipQuiz(): boolean {
    // URL bypasses for testing / debugging the quiz without manually clearing localStorage:
    //   ?quiz=show  — force the section visible even if the gate is set
    //   ?quiz=reset — clear the gate entirely (one-time, persists after reload)
    try {
      const params = new URLSearchParams(window.location.search);
      const quizParam = params.get('quiz');
      if (quizParam === 'reset') {
        try { localStorage.removeItem(STORAGE_KEY); } catch { /* storage off */ }
        return false;
      }
      if (quizParam === 'show') return false;
    } catch { /* SSR-safe */ }

    try {
      const raw = localStorage.getItem(STORAGE_KEY);
      if (!raw) return false;
      const parsed = JSON.parse(raw);
      if (!parsed || !parsed.at) return false;
      const ageMs = Date.now() - new Date(parsed.at).getTime();
      const ageHours = ageMs / (1000 * 60 * 60);
      return ageHours < REVISIT_HOURS;
    } catch {
      return false;
    }
  }

  function markCompleted() {
    try {
      localStorage.setItem(STORAGE_KEY, JSON.stringify({ at: new Date().toISOString() }));
    } catch {
      // Storage disabled — silently degrade
    }
  }

  function formatNumber(value: number, shape: CounterShape, locale: 'es' | 'en'): string {
    const loc = locale === 'es' ? 'es-MX' : 'en-US';
    if (shape === 'currency') {
      return new Intl.NumberFormat(loc, {
        style: 'currency', currency: 'USD',
        maximumFractionDigits: 0, minimumFractionDigits: 0,
      }).format(value);
    }
    if (shape === 'percent') {
      const n = new Intl.NumberFormat(loc, { maximumFractionDigits: 0 }).format(value);
      return locale === 'es' ? `${n} %` : `${n}%`;
    }
    if (shape === 'multiplier') {
      const n = new Intl.NumberFormat(loc, { maximumFractionDigits: 0 }).format(value);
      return `${n}×`;
    }
    if (shape === 'hours') {
      const fracDigits = value < 10 ? 1 : 0;
      const n = new Intl.NumberFormat(loc, {
        minimumFractionDigits: fracDigits,
        maximumFractionDigits: fracDigits,
      }).format(value);
      return locale === 'es' ? `${n} h` : `${n}h`;
    }
    return new Intl.NumberFormat(loc, { maximumFractionDigits: 0 }).format(value);
  }

  function easeOutCubic(t: number): number {
    return 1 - Math.pow(1 - t, 3);
  }

  function animateCounter(
    el: HTMLElement, from: number, to: number, durationMs: number,
    shape: CounterShape, locale: 'es' | 'en',
  ) {
    const start = performance.now();
    function tick(now: number) {
      const t = Math.min(1, (now - start) / durationMs);
      const eased = easeOutCubic(t);
      const raw = from + (to - from) * eased;
      const value = (shape === 'hours' && to < 10) ? Math.round(raw * 10) / 10 : Math.round(raw);
      el.textContent = formatNumber(value, shape, locale);
      if (t < 1) requestAnimationFrame(tick);
    }
    requestAnimationFrame(tick);
  }

  function initQuiz() {
    const section = document.getElementById('industry-insight-quiz');
    if (!section) return;

    if (shouldSkipQuiz()) {
      section.hidden = true;
      return;
    }

    const eyebrowEl = document.getElementById('quiz-eyebrow') as HTMLElement | null;
    const questionEl = document.getElementById('quiz-question') as HTMLElement | null;
    const questionTextEl = document.getElementById('quiz-question-text') as HTMLElement | null;
    const optionsEl = document.getElementById('quiz-options') as HTMLElement | null;
    const revealEl = document.getElementById('quiz-reveal') as HTMLElement | null;
    const guessEl = document.getElementById('quiz-guess') as HTMLElement | null;
    const guessLabelEl = document.getElementById('quiz-guess-label') as HTMLElement | null;
    const guessValueEl = document.getElementById('quiz-guess-value') as HTMLElement | null;
    const realityValueEl = document.getElementById('quiz-reality-value') as HTMLElement | null;
    const revealBodyEl = document.getElementById('quiz-reveal-body') as HTMLElement | null;
    const revealSourceEl = document.getElementById('quiz-reveal-source') as HTMLElement | null;
    const progressEl = document.getElementById('quiz-progress') as HTMLElement | null;
    const nextBtn = document.getElementById('quiz-next') as HTMLButtonElement | null;
    const finalEl = document.getElementById('quiz-final') as HTMLElement | null;
    const finalCtaBtn = document.getElementById('quiz-final-cta') as HTMLButtonElement | null;
    const skipBtn = document.getElementById('quiz-skip') as HTMLButtonElement | null;

    if (!eyebrowEl || !questionEl || !questionTextEl || !optionsEl || !revealEl
      || !guessEl || !guessLabelEl || !guessValueEl || !realityValueEl
      || !revealBodyEl || !revealSourceEl || !progressEl
      || !nextBtn || !finalEl || !finalCtaBtn || !skipBtn) {
      return;
    }

    const state: QuizState = { idx: 0, phase: 'question', selected: null };
    let autoAdvanceTimer: number | null = null;
    const staggerTimers: number[] = [];

    function clearStagger() {
      while (staggerTimers.length) {
        const id = staggerTimers.pop();
        if (id !== undefined) window.clearTimeout(id);
      }
    }

    function clearAutoAdvance() {
      if (autoAdvanceTimer !== null) {
        window.clearTimeout(autoAdvanceTimer);
        autoAdvanceTimer = null;
      }
    }

    function renderQuestion() {
      const q = QUESTIONS[state.idx];
      const lang = getLang();

      eyebrowEl!.textContent = lang === 'es' ? q.eyebrowEs : q.eyebrowEn;
      questionTextEl!.textContent = lang === 'es' ? q.questionEs : q.questionEn;

      optionsEl!.innerHTML = '';
      q.options.forEach((opt, i) => {
        const btn = document.createElement('button');
        btn.type = 'button';
        btn.className = 'quiz-option';
        btn.setAttribute('role', 'radio');
        btn.setAttribute('aria-checked', 'false');
        btn.dataset.idx = String(i);

        const key = document.createElement('span');
        key.className = 'quiz-option-key';
        key.textContent = String(i + 1);
        btn.appendChild(key);

        const label = document.createElement('span');
        label.textContent = lang === 'es' ? opt.es : opt.en;
        btn.appendChild(label);

        btn.addEventListener('click', () => handleSelect(i));
        optionsEl!.appendChild(btn);
      });

      questionEl!.hidden = false;
      revealEl!.hidden = true;
      finalEl!.hidden = true;
    }

    function renderReveal() {
      const q = QUESTIONS[state.idx];
      const lang = getLang();
      const reduced = prefersReducedMotion();
      const nailed = state.selected === q.correctIdx;
      const correctOpt = q.options[q.correctIdx];
      const selectedOpt = state.selected !== null ? q.options[state.selected] : null;

      // Reset transient classes
      guessEl!.classList.remove('is-nailed');
      revealBodyEl!.classList.remove('is-in');
      revealSourceEl!.classList.remove('is-in');
      progressEl!.classList.remove('is-in');
      nextBtn!.classList.remove('is-in');

      // Update mini-label data attributes + text
      if (nailed) {
        guessEl!.classList.add('is-nailed');
        guessLabelEl!.setAttribute('data-en', 'YOU NAILED IT');
        guessLabelEl!.setAttribute('data-es', 'LO ACERTASTE');
        guessLabelEl!.textContent = lang === 'es' ? 'LO ACERTASTE' : 'YOU NAILED IT';
      } else {
        guessLabelEl!.setAttribute('data-en', 'YOU GUESSED');
        guessLabelEl!.setAttribute('data-es', 'TÚ DIJISTE');
        guessLabelEl!.textContent = lang === 'es' ? 'TÚ DIJISTE' : 'YOU GUESSED';
      }

      // Guess value = the option text the user picked (in current locale)
      guessValueEl!.textContent = selectedOpt ? (lang === 'es' ? selectedOpt.es : selectedOpt.en) : '';

      // Reality value: final value if reduced motion, else starting "zero" formatted for the shape
      realityValueEl!.textContent = reduced
        ? formatNumber(correctOpt.value, q.barShape, lang)
        : formatNumber(0, q.barShape, lang);

      // Body + source
      revealBodyEl!.textContent = lang === 'es' ? q.bodyEs : q.bodyEn;
      revealSourceEl!.textContent = lang === 'es' ? q.sourceEs : q.sourceEn;

      // Progress dots
      progressEl!.innerHTML = '';
      for (let i = 0; i < QUESTIONS.length; i++) {
        const dot = document.createElement('span');
        dot.className = 'quiz-dot' + (i <= state.idx ? ' is-on' : '');
        progressEl!.appendChild(dot);
      }

      // Mark options as correct/wrong + disable
      const optionEls = optionsEl!.querySelectorAll<HTMLButtonElement>('.quiz-option');
      optionEls.forEach((el, i) => {
        if (i === q.correctIdx) el.classList.add('is-correct');
        else el.classList.add('is-wrong');
        el.setAttribute('aria-checked', i === state.selected ? 'true' : 'false');
        el.disabled = true;
      });

      questionEl!.hidden = true;
      revealEl!.hidden = false;
      finalEl!.hidden = true;

      clearStagger();

      if (reduced) {
        revealBodyEl!.classList.add('is-in');
        revealSourceEl!.classList.add('is-in');
        progressEl!.classList.add('is-in');
        nextBtn!.classList.add('is-in');
        return;
      }

      // Cross-fade in + start counter
      staggerTimers.push(window.setTimeout(() => {
        animateCounter(realityValueEl!, 0, correctOpt.value, COUNTER_DURATION_MS, q.barShape, lang);
        revealBodyEl!.classList.add('is-in');
        revealSourceEl!.classList.add('is-in');
        progressEl!.classList.add('is-in');
        nextBtn!.classList.add('is-in');
      }, REVEAL_DELAY_MS));

      // Auto-advance unless reduced motion. Pauses if the tab loses focus mid-read,
      // then re-arms with a fresh full duration on tab return — never auto-advances
      // while the user is looking at another tab.
      armAutoAdvance();
    }

    function armAutoAdvance() {
      clearAutoAdvance();
      if (document.visibilityState === 'hidden') return;
      autoAdvanceTimer = window.setTimeout(() => {
        advance();
      }, AUTO_ADVANCE_MS);
    }

    function renderFinal() {
      const lang = getLang();
      finalEl!.querySelectorAll('[data-en][data-es]').forEach((el) => {
        const text = el.getAttribute(`data-${lang}`);
        if (text) el.textContent = text;
      });
      questionEl!.hidden = true;
      revealEl!.hidden = true;
      finalEl!.hidden = false;
      eyebrowEl!.textContent = lang === 'es' ? 'Listo' : 'Done';
      markCompleted();
    }

    function fadeSwap(callback: () => void) {
      if (prefersReducedMotion()) {
        callback();
        return;
      }
      const active = !questionEl!.hidden ? questionEl!
        : !revealEl!.hidden ? revealEl!
        : finalEl!;
      active.classList.add('is-fading');
      window.setTimeout(() => {
        callback();
        active.classList.remove('is-fading');
      }, 200);
    }

    function handleSelect(i: number) {
      if (state.phase !== 'question') return;
      const opts = optionsEl!.querySelectorAll<HTMLButtonElement>('.quiz-option');
      const btn = opts[i];
      if (btn) btn.classList.add('is-tapped');
      state.selected = i;
      state.phase = 'reveal';
      // 120ms tap-confirm press feedback BEFORE the cross-fade — acknowledges the input
      window.setTimeout(() => fadeSwap(renderReveal), 120);
    }

    function advance() {
      clearAutoAdvance();
      clearStagger();
      if (state.idx < QUESTIONS.length - 1) {
        state.idx += 1;
        state.phase = 'question';
        state.selected = null;
        fadeSwap(renderQuestion);
      } else {
        state.phase = 'final';
        fadeSwap(renderFinal);
      }
    }

    function skipQuiz() {
      clearAutoAdvance();
      clearStagger();
      markCompleted();
      section!.hidden = true;
    }

    // Wire static buttons
    nextBtn.addEventListener('click', () => {
      if (state.phase === 'reveal') advance();
    });

    finalCtaBtn.addEventListener('click', () => {
      const fn = (window as unknown as { jufipaiOpenNewsletter?: () => void }).jufipaiOpenNewsletter;
      if (typeof fn === 'function') fn();
    });

    skipBtn.addEventListener('click', skipQuiz);

    // Pause auto-advance when the tab loses focus. Re-arm with a fresh full
    // duration on return — so the user never comes back to a quiz that already
    // advanced past the reveal they were trying to read.
    document.addEventListener('visibilitychange', () => {
      if (state.phase !== 'reveal') return;
      if (document.visibilityState === 'hidden') {
        clearAutoAdvance();
      } else {
        armAutoAdvance();
      }
    });

    // Keyboard handling: 1/2/3 to pick, Enter/Space to advance, Esc to skip.
    // Scoped: ignore when focus is in an input/textarea/contenteditable OR inside the newsletter modal
    // (prevents hijacking Space/Enter/digit keys from the modal email field).
    document.addEventListener('keydown', (e) => {
      if (section!.hidden) return;
      const target = e.target as HTMLElement | null;
      if (target) {
        const tag = target.tagName;
        if (tag === 'INPUT' || tag === 'TEXTAREA' || tag === 'SELECT' || target.isContentEditable) return;
        if (target.closest('#jufipai-nl-modal, dialog[open]')) return;
      }
      const rect = section!.getBoundingClientRect();
      const inView = rect.top < window.innerHeight && rect.bottom > 0;
      if (!inView) return;

      if (e.key === 'Escape') {
        e.preventDefault();
        skipQuiz();
        return;
      }

      if (state.phase === 'question') {
        if (e.key === '1' || e.key === '2' || e.key === '3') {
          e.preventDefault();
          handleSelect(parseInt(e.key, 10) - 1);
        }
      } else if (state.phase === 'reveal') {
        if (e.key === 'Enter' || e.key === ' ') {
          e.preventDefault();
          advance();
        }
      }
    });

    renderQuestion();
  }

  initQuiz();
  document.addEventListener('astro:after-swap', initQuiz);
</script>
