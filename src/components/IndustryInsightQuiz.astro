---
// IndustryInsightQuiz — 5-card single-question-per-screen, auto-advance, ES+EN.
// Provokes "you're behind" recognition via percentages + dollar amounts.
// localStorage gate: jufipai_quiz_v1 — skip on revisit within 24h.
// Final card CTA opens NewsletterModal via window.jufipaiOpenNewsletter().
---

<section class="quiz-section" id="industry-insight-quiz" aria-label="Industry Insight Quiz">
  <div class="quiz-shell">

    <span class="quiz-eyebrow" id="quiz-eyebrow"
      data-en="Question 1 of 5" data-es="Pregunta 1 de 5">
      Pregunta 1 de 5
    </span>

    <!-- QUESTION CARD -->
    <div class="quiz-question" id="quiz-question">
      <h2 class="quiz-headline" id="quiz-question-text"></h2>
      <div class="quiz-options" role="radiogroup" id="quiz-options" aria-label="Answer options"></div>
    </div>

    <!-- REVEAL CARD -->
    <div class="quiz-reveal" id="quiz-reveal" hidden>
      <div class="quiz-bars" id="quiz-bars"></div>
      <p class="quiz-reveal-body" id="quiz-reveal-body" aria-live="polite"></p>
      <p class="quiz-reveal-source" id="quiz-reveal-source"></p>
      <div class="quiz-progress" id="quiz-progress" aria-hidden="true"></div>
      <button type="button" class="quiz-next" id="quiz-next"
        data-en="Next" data-es="Siguiente">
        Siguiente
      </button>
    </div>

    <!-- FINAL CARD -->
    <div class="quiz-final" id="quiz-final" hidden>
      <h2 class="quiz-final-headline"
        data-en="Your industry is leaving hours and money on the table."
        data-es="Tu industria está dejando horas y dinero sobre la mesa.">
        Tu industria está dejando horas y dinero sobre la mesa.
      </h2>
      <p class="quiz-final-sub"
        data-en="We can help. Get the next system before everyone else."
        data-es="Podemos ayudarte. Recibe el próximo sistema antes que nadie.">
        Podemos ayudarte. Recibe el próximo sistema antes que nadie.
      </p>
      <button type="button" class="quiz-final-cta" id="quiz-final-cta"
        data-en="Get the next one"
        data-es="Recibirlo">
        Recibirlo
      </button>
    </div>

    <button type="button" class="quiz-skip" id="quiz-skip"
      data-en="Skip" data-es="Saltar"
      aria-label="Skip quiz">
      Saltar
    </button>
  </div>
</section>

<style>
  .quiz-section {
    padding: var(--space-2xl) var(--space-md);
    background: var(--color-papel);
    display: flex;
    justify-content: center;
  }

  .quiz-shell {
    position: relative;
    width: 100%;
    max-width: 560px;
    background: var(--color-surface);
    border: 1px solid var(--color-arena);
    border-radius: var(--radius-modal);
    padding: 3rem 1.5rem 2rem;
    box-shadow: 0 12px 32px rgba(31, 36, 33, 0.06);
  }

  @media (min-width: 768px) {
    .quiz-shell {
      padding: 3.5rem 3rem 2.5rem;
    }
  }

  .quiz-eyebrow {
    display: inline-block;
    font-family: var(--font-mono);
    font-size: 10px;
    font-weight: 600;
    letter-spacing: 1.2px;
    text-transform: uppercase;
    color: var(--color-jade-deep);
    background: var(--color-jade-soft);
    padding: 4px 10px;
    border-radius: var(--radius-pill);
    margin-bottom: 1.25rem;
  }

  .quiz-headline {
    font-family: var(--font-display);
    font-size: clamp(1.5rem, 3vw, 2rem);
    font-weight: 600;
    line-height: 1.2;
    letter-spacing: -0.015em;
    color: var(--color-carbon);
    margin: 0 0 1.75rem;
  }

  .quiz-options {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .quiz-option {
    width: 100%;
    text-align: left;
    padding: 1rem 1.25rem;
    font-family: var(--font-body);
    font-size: 1rem;
    color: var(--color-carbon);
    background: var(--color-surface);
    border: 1.5px solid var(--color-arena);
    border-radius: 12px;
    cursor: pointer;
    display: flex;
    align-items: center;
    gap: 0.75rem;
    transition: border-color var(--duration-base) var(--ease-spring),
                background var(--duration-base) var(--ease-spring),
                transform var(--duration-base) var(--ease-spring);
  }

  .quiz-option:hover {
    border-color: var(--color-jade);
    background: var(--color-jade-soft);
    transform: translateX(2px);
  }

  .quiz-option:focus-visible {
    outline: 2px solid var(--color-jade);
    outline-offset: 2px;
  }

  .quiz-option-key {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--color-carbon-soft);
    width: 1.5rem;
    flex-shrink: 0;
  }

  .quiz-option.is-correct {
    border-color: var(--color-jade);
    background: var(--color-jade);
    color: #FFFFFF;
  }

  .quiz-option.is-correct .quiz-option-key {
    color: rgba(255, 255, 255, 0.85);
  }

  .quiz-option.is-wrong {
    opacity: 0.55;
  }

  .quiz-question,
  .quiz-reveal,
  .quiz-final {
    transition: opacity 200ms var(--ease-spring);
  }

  .quiz-question.is-fading,
  .quiz-reveal.is-fading,
  .quiz-final.is-fading {
    opacity: 0;
  }

  .quiz-bars {
    display: flex;
    flex-direction: column;
    gap: 0.85rem;
    margin: 0 0 1.5rem;
  }

  .quiz-bar-row {
    display: grid;
    grid-template-columns: 1fr auto;
    grid-template-rows: auto auto;
    column-gap: 0.75rem;
    row-gap: 0.3rem;
    align-items: center;
    padding: 0.35rem 0.5rem;
    border-radius: 8px;
    cursor: pointer;
    opacity: 0;
    transform: translateY(8px);
    transition: opacity 280ms var(--ease-spring),
                transform 280ms var(--ease-spring),
                background 200ms var(--ease-spring),
                box-shadow 200ms var(--ease-spring);
  }

  .quiz-bar-row.is-in {
    opacity: 1;
    transform: translateY(0);
  }

  .quiz-bar-row:hover,
  .quiz-bar-row:focus-visible {
    background: rgba(14, 124, 102, 0.04);
    outline: none;
  }

  .quiz-bar-row:focus-visible {
    box-shadow: 0 0 0 2px var(--color-jade);
  }

  .quiz-bar-label {
    grid-column: 1;
    grid-row: 1;
    font-family: var(--font-mono);
    font-size: 10px;
    font-weight: 600;
    letter-spacing: 1.2px;
    text-transform: uppercase;
    color: var(--color-carbon-soft);
  }

  .quiz-bar-row.is-correct .quiz-bar-label {
    color: var(--color-jade-deep);
  }

  .quiz-bar-value {
    grid-column: 2;
    grid-row: 1;
    font-family: var(--font-mono);
    font-size: 0.95rem;
    font-weight: 600;
    color: var(--color-carbon-soft);
    font-variant-numeric: tabular-nums;
  }

  .quiz-bar-row.is-correct .quiz-bar-value {
    color: var(--color-jade-deep);
    font-size: 1rem;
  }

  .quiz-bar-track {
    grid-column: 1 / -1;
    grid-row: 2;
    height: 12px;
    width: 100%;
    background: var(--color-arena);
    border-radius: var(--radius-pill);
    overflow: hidden;
  }

  .quiz-bar-fill {
    --bar-target: 0%;
    width: 0;
    height: 100%;
    border-radius: var(--radius-pill);
    transition: width 700ms cubic-bezier(0.34, 1.56, 0.64, 1);
  }

  .quiz-bar-row.is-fill .quiz-bar-fill {
    width: var(--bar-target);
  }

  .quiz-bar-row.is-correct .quiz-bar-fill {
    background: var(--color-jade);
  }

  .quiz-bar-row.is-user .quiz-bar-fill {
    background: var(--color-jade-soft);
    border: 1px solid var(--color-jade);
    box-sizing: border-box;
  }

  .quiz-bar-row.is-other .quiz-bar-fill {
    background: var(--color-carbon-soft);
    opacity: 0.45;
  }

  .quiz-bar-row.is-pulsing {
    animation: quizBarPulse 600ms ease-out;
  }

  @keyframes quizBarPulse {
    0%   { box-shadow: 0 0 0 0 rgba(14, 124, 102, 0.4); }
    100% { box-shadow: 0 0 0 14px rgba(14, 124, 102, 0); }
  }

  @media (max-width: 640px) {
    .quiz-bar-track { height: 10px; }
    .quiz-bar-value { font-size: 0.85rem; }
    .quiz-bar-row.is-correct .quiz-bar-value { font-size: 0.95rem; }
  }

  .quiz-reveal-body {
    position: relative;
    font-family: var(--font-body);
    font-size: 1.0625rem;
    line-height: 1.55;
    color: var(--color-carbon);
    margin: 0 0 1rem;
    padding-left: 0.85rem;
    opacity: 0;
    transition: opacity 240ms var(--ease-spring);
  }

  .quiz-reveal-body::before {
    content: '';
    position: absolute;
    left: 0;
    top: 0;
    width: 3px;
    height: 0;
    background: var(--color-jade);
    border-radius: 2px;
    transition: height 220ms var(--ease-spring);
  }

  .quiz-reveal-body.is-in {
    opacity: 1;
  }

  .quiz-reveal-body.is-in::before {
    height: 100%;
  }

  .quiz-reveal-source {
    font-family: var(--font-mono);
    font-size: 10px;
    line-height: 1.4;
    color: var(--color-carbon-soft);
    margin: 0 0 1.5rem;
    opacity: 0;
    transition: opacity 240ms var(--ease-spring);
  }

  .quiz-reveal-source.is-in { opacity: 1; }

  .quiz-progress,
  .quiz-next {
    opacity: 0;
    transition: opacity 240ms var(--ease-spring),
                background var(--duration-base) var(--ease-spring),
                transform var(--duration-base) var(--ease-spring);
  }

  .quiz-progress.is-in,
  .quiz-next.is-in { opacity: 1; }

  .quiz-progress {
    display: flex;
    gap: 0.5rem;
    justify-content: center;
    margin-bottom: 1.5rem;
  }

  .quiz-dot {
    width: 8px;
    height: 8px;
    border-radius: var(--radius-pill);
    background: var(--color-arena);
    transition: background var(--duration-base) var(--ease-spring);
  }

  .quiz-dot.is-on {
    background: var(--color-jade);
  }

  .quiz-next,
  .quiz-final-cta {
    width: 100%;
    padding: 0.9rem 1.25rem;
    font-family: var(--font-body);
    font-size: 1rem;
    font-weight: 600;
    color: #FFFFFF;
    background: var(--color-jade);
    border: none;
    border-radius: 12px;
    cursor: pointer;
    transition: background var(--duration-base) var(--ease-spring),
                transform var(--duration-base) var(--ease-spring),
                opacity 240ms var(--ease-spring);
  }

  .quiz-next:hover,
  .quiz-final-cta:hover {
    background: var(--color-jade-deep);
    transform: translateY(-1px);
  }

  .quiz-next:focus-visible,
  .quiz-final-cta:focus-visible {
    outline: 2px solid var(--color-jade);
    outline-offset: 2px;
  }

  .quiz-final-headline {
    font-family: var(--font-display);
    font-size: clamp(1.5rem, 3vw, 1.875rem);
    font-weight: 600;
    line-height: 1.2;
    color: var(--color-carbon);
    margin: 0 0 0.75rem;
  }

  .quiz-final-sub {
    font-family: var(--font-body);
    font-size: 1rem;
    line-height: 1.55;
    color: var(--color-carbon-soft);
    margin: 0 0 1.5rem;
  }

  .quiz-skip {
    position: absolute;
    top: 1rem;
    right: 1rem;
    background: transparent;
    border: none;
    color: var(--color-carbon-soft);
    font-family: var(--font-body);
    font-size: 0.8125rem;
    cursor: pointer;
    padding: 0.25rem 0.5rem;
    text-decoration: underline;
    text-decoration-color: transparent;
    transition: text-decoration-color var(--duration-base) var(--ease-spring),
                color var(--duration-base) var(--ease-spring);
  }

  .quiz-skip:hover {
    color: var(--color-carbon);
    text-decoration-color: var(--color-carbon-soft);
  }

  @media (prefers-reduced-motion: reduce) {
    .quiz-question,
    .quiz-reveal,
    .quiz-final,
    .quiz-option,
    .quiz-next,
    .quiz-final-cta,
    .quiz-bar-row,
    .quiz-bar-fill,
    .quiz-reveal-body,
    .quiz-reveal-source,
    .quiz-progress {
      transition: none !important;
      animation: none !important;
    }
    .quiz-bar-row { opacity: 1; transform: none; }
    .quiz-bar-fill { width: var(--bar-target); }
    .quiz-reveal-body,
    .quiz-reveal-source,
    .quiz-progress,
    .quiz-next { opacity: 1; }
    .quiz-reveal-body::before { height: 100%; }
  }
</style>

<script>
  // IndustryInsightQuiz — vanilla TS, no dependencies.
  const STORAGE_KEY = 'jufipai_quiz_v1';
  const REVISIT_HOURS = 24;
  const AUTO_ADVANCE_MS = 5000;

  type CounterShape = 'count' | 'currency' | 'percent' | 'hours';

  type QuestionData = {
    eyebrowEn: string;
    eyebrowEs: string;
    questionEn: string;
    questionEs: string;
    options: { en: string; es: string; value: number }[];
    correctIdx: number;
    barShape: CounterShape;
    answerEn: string;
    answerEs: string;
    bodyEn: string;
    bodyEs: string;
    sourceEn: string;
    sourceEs: string;
  };

  const QUESTIONS: QuestionData[] = [
    {
      eyebrowEn: 'Question 1 of 5 — Real Estate',
      eyebrowEs: 'Pregunta 1 de 5 — Bienes Raíces',
