      eyebrowEs: 'Pregunta 2 de 5 — Reclutamiento',
      questionEn: 'How many staffing agencies operate in Texas?',
      questionEs: '¿Cuántas agencias de reclutamiento operan en Texas?',
      options: [
        { en: '800', es: '800', value: 800 },
        { en: '1,500', es: '1.500', value: 1500 },
        { en: '2,500+', es: '2.500+', value: 2500 },
      ],
