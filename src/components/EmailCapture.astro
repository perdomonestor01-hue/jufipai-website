---
// Email capture form — posts to Apps Script with type: 'subscribe'
// Appends to "Subscribers" tab, sends welcome auto-reply
---

<section class="capture-section">
  <div class="capture-inner">
    <div class="capture-copy">
      <span class="section-label label-style" data-en="Stay in the loop" data-es="Mantente al dia">Stay in the loop</span>
      <h2 class="capture-headline" data-en="Get the next system before everyone else." data-es="Recibe el proximo sistema antes que nadie.">Get the next system before everyone else.</h2>
      <p class="capture-sub" data-en="One email when we publish something worth your time. No spam, no schedules, no filler." data-es="Un correo cuando publicamos algo que vale tu tiempo. Sin spam, sin calendarios, sin relleno.">One email when we publish something worth your time. No spam, no schedules, no filler.</p>
    </div>

    <form class="capture-form" id="capture-form" novalidate>
      <label class="sr-only" for="capture-email" data-en="Email address" data-es="Correo electronico">Email address</label>
      <input
        type="email"
        id="capture-email"
        name="email"
        class="capture-input"
        placeholder="you@company.com"
        data-en-placeholder="you@company.com"
        data-es-placeholder="tu@empresa.com"
        autocomplete="email"
        required
      />
      <!-- Honeypot: must stay empty -->
      <input type="text" name="website" class="honeypot" tabindex="-1" aria-hidden="true" autocomplete="off" />
      <button type="submit" class="capture-btn" data-en="Join the list" data-es="Unirme">
        Join the list <span aria-hidden="true">&rarr;</span>
      </button>
      <p class="capture-status" id="capture-status" role="status" aria-live="polite"></p>
    </form>
  </div>
</section>

<script>
  const SHEET_URL = 'https://script.google.com/macros/s/AKfycbxJo9lyHS2-qwIF1f8OPh5nli51jP3ZzagZ0MInGnk-7g69iSqQw8T0QHpDiBbkUVFt/exec';
  const EMAIL_REGEX = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;

  function getLang() {
    return (document.documentElement.lang === 'es') ? 'es' : 'en';
  }

  function translate(en, es) {
    return getLang() === 'es' ? es : en;
  }

  const form = document.getElementById('capture-form');
  const input = document.getElementById('capture-email');
  const status = document.getElementById('capture-status');
  const button = form ? form.querySelector('button[type="submit"]') : null;

  if (form && input && status && button) {
    form.addEventListener('submit', async (e) => {
      e.preventDefault();

      const email = input.value.trim();
      const honeypot = form.querySelector('input[name="website"]').value;

      // Silent for bots
      if (honeypot) {
        status.textContent = translate("You're in. Talk soon.", 'Listo. Hablamos pronto.');
        status.className = 'capture-status success';
        input.value = '';
        return;
      }

      if (!EMAIL_REGEX.test(email)) {
        status.textContent = translate('Please enter a valid email.', 'Por favor ingresa un correo valido.');
        status.className = 'capture-status error';
        return;
      }

      status.textContent = translate('Adding you to the list...', 'Agregandote a la lista...');
      status.className = 'capture-status pending';
      button.disabled = true;

      try {
        await fetch(SHEET_URL, {
          method: 'POST',
          mode: 'no-cors',
          headers: { 'Content-Type': 'text/plain' },
          body: JSON.stringify({
            type: 'subscribe',
            email: email,
            locale: getLang(),
            source: 'homepage_capture',
            userAgent: navigator.userAgent,
            referrer: document.referrer,
          }),
        });
        status.textContent = translate("You're in. Check your inbox.", 'Listo. Revisa tu bandeja.');
        status.className = 'capture-status success';
        input.value = '';
      } catch (err) {
        status.textContent = translate('Something went wrong. Try again in a moment.', 'Algo fallo. Intenta de nuevo en un momento.');
        status.className = 'capture-status error';
      } finally {
        button.disabled = false;
      }
    });
  }
</script>

<style>
  .capture-section {
    padding: var(--space-xl) 0;
    background: var(--bg-dark);
    position: relative;
    overflow: hidden;
  }

  .capture-inner {
    max-width: var(--max-width);
    margin: 0 auto;
    padding: 0 var(--space-md);
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-xl);
    align-items: center;
  }

  .capture-copy .section-label {
    color: var(--accent);
  }

  .capture-headline {
    font-family: var(--font-display);
    font-size: clamp(1.75rem, 3vw, 2.25rem);
    font-weight: 700;
    line-height: 1.2;
    color: var(--text-on-dark);
    margin: var(--space-sm) 0 var(--space-xs);
    max-width: 22rem;
    letter-spacing: -0.01em;
  }

  .capture-sub {
    font-size: 1rem;
    line-height: 1.65;
    color: var(--text-on-dark-muted);
    margin: 0;
    max-width: 26rem;
  }

  .capture-form {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    align-items: stretch;
    position: relative;
  }

  .capture-input {
    flex: 1 1 18rem;
    min-width: 0;
    padding: 0.9rem 1.1rem;
    font-family: var(--font-body);
    font-size: 1rem;
    color: var(--text-on-dark);
    background: rgba(255, 255, 255, 0.06);
    border: 1.5px solid rgba(255, 255, 255, 0.18);
    border-radius: 10px;
    outline: none;
    transition: border-color var(--duration) var(--ease), background var(--duration) var(--ease);
  }

  .capture-input::placeholder {
    color: rgba(255, 255, 255, 0.4);
  }

  .capture-input:focus {
    border-color: var(--accent);
    background: rgba(255, 255, 255, 0.1);
  }

  .capture-btn {
    padding: 0.9rem 1.5rem;
    font-family: var(--font-body);
    font-size: 1rem;
    font-weight: 600;
    color: var(--white);
    background: #2563EB;
    border: none;
    border-radius: 10px;
    cursor: pointer;
    transition: background var(--duration) var(--ease), transform var(--duration) var(--ease);
    white-space: nowrap;
  }

  .capture-btn:hover:not(:disabled) {
    background: #1D4ED8;
    transform: translateY(-1px);
  }

  .capture-btn:disabled {
    opacity: 0.6;
    cursor: wait;
  }

  .capture-status {
    width: 100%;
    margin: 0.25rem 0 0;
    font-size: 0.875rem;
    color: var(--text-on-dark-muted);
    min-height: 1.25rem;
  }

  .capture-status.success {
    color: #4ADE80;
  }

  .capture-status.error {
    color: #F87171;
  }

  .capture-status.pending {
    color: rgba(255, 255, 255, 0.6);
  }

  .honeypot {
    position: absolute;
    left: -10000px;
    top: auto;
    width: 1px;
    height: 1px;
    overflow: hidden;
    opacity: 0;
  }

  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }

  @media (max-width: 768px) {
    .capture-inner {
      grid-template-columns: 1fr;
      gap: var(--space-lg);
    }
  }
</style>
