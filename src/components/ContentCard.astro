---
import type { Article, ContentType } from '../lib/types';

interface Props {
  article: Article;
  featured?: boolean;
}

const { article, featured = false } = Astro.props;

const type = article.contentType as ContentType;
const date = new Date(article.createdAt).toLocaleDateString('en-US', {
  month: 'short',
  day: 'numeric',
  year: 'numeric',
});

// Type-based label/badge (visible chip on each card)
const typeLabels: Record<string, { en: string; es: string }> = {
  article:        { en: 'Article',   es: 'Artículo'   },
  deep_question:  { en: 'Question',  es: 'Pregunta'   },
  unpopular_take: { en: 'Take',      es: 'Opinión'    },
  image_quote:    { en: 'Thought',   es: 'Pensamiento'},
  tip:            { en: 'Tip',       es: 'Consejo'    },
  creative:       { en: 'Creative',  es: 'Creativo'   },
  riddle:         { en: 'Shuffle',   es: 'Mezcla'     },
};
const label = typeLabels[type] || typeLabels.article;
---

{
  type === 'deep_question' ? (
    <article class="card card-question reveal" data-type={type}>
      <span class="card-badge card-badge--question" data-en={label.en} data-es={label.es}>{label.en}</span>
      <blockquote class="question-text">
        <p>{article.title}</p>
      </blockquote>
      <div class="card-meta">
        <span class="card-date">{date}</span>
        {article.linkedinUrl && (
          <a
            href={article.linkedinUrl}
            target="_blank"
            rel="noopener noreferrer"
            class="card-link"
            data-en="Read on LinkedIn"
            data-es="Leer en LinkedIn"
          >
            Read on LinkedIn
          </a>
        )}
      </div>
    </article>
  ) : type === 'unpopular_take' ? (
    <article class="card card-take reveal" data-type={type}>
      <span class="card-ribbon" aria-hidden="true">
        <span class="card-ribbon-text" data-en="Take" data-es="Opinión">Take</span>
      </span>
      {article.image && (
        <div class="card-image">
          <img src={article.image} alt={article.title} loading="lazy" decoding="async" />
          {article.imageAttribution && (
            <span class="card-attribution">{article.imageAttribution}</span>
          )}
        </div>
      )}
      <div class="take-content">
        <span class="card-badge card-badge--take" data-en={label.en} data-es={label.es}>{label.en}</span>
        <h3 class="card-title">{article.title}</h3>
        <p class="card-teaser">{article.teaser}</p>
      </div>
      <div class="card-meta">
        <span class="card-date">{date}</span>
        <span class="card-readtime">
          {article.readTime}{' '}
          <span data-en="min read" data-es="min de lectura">
            min read
          </span>
        </span>
        {article.linkedinUrl && (
          <a
            href={article.linkedinUrl}
            target="_blank"
            rel="noopener noreferrer"
            class="card-link"
            data-en="Read on LinkedIn"
            data-es="Leer en LinkedIn"
          >
            Read on LinkedIn
          </a>
        )}
      </div>
    </article>
  ) : type === 'image_quote' ? (
    <article class="card card-imagequote reveal" data-type={type}>
      {article.image && (
        <div class="card-image card-image--full">
          <img src={article.image} alt={article.title} loading="lazy" decoding="async" />
          <div class="card-image-scrim" />
          <div class="card-image-quote">
            <span class="card-badge card-badge--imagequote" data-en={label.en} data-es={label.es}>{label.en}</span>
            <p class="imagequote-title">{article.title}</p>
          </div>
        </div>
      )}
      <div class="card-meta card-meta--padded">
        <span class="card-date">{date}</span>
        <span class="card-readtime">
          {article.readTime}{' '}
          <span data-en="min read" data-es="min de lectura">min read</span>
        </span>
        {article.linkedinUrl && (
          <a href={article.linkedinUrl} target="_blank" rel="noopener noreferrer" class="card-link" data-en="Read on LinkedIn" data-es="Leer en LinkedIn">
            Read on LinkedIn
          </a>
        )}
      </div>
    </article>
  ) : type === 'tip' ? (
    <article class="card card-tip reveal" data-type={type}>
      <div class="tip-content">
        <span class="card-badge card-badge--tip" data-en={label.en} data-es={label.es}>{label.en}</span>
        <h3 class="card-title tip-title">
          <span class="tip-number" aria-hidden="true">#</span>{article.title}
        </h3>
        <p class="card-teaser">{article.teaser}</p>
      </div>
      <div class="card-meta">
        <span class="card-date">{date}</span>
        <span class="card-readtime">
          {article.readTime}{' '}
          <span data-en="min read" data-es="min de lectura">min read</span>
        </span>
        {article.linkedinUrl && (
          <a href={article.linkedinUrl} target="_blank" rel="noopener noreferrer" class="card-link" data-en="Read on LinkedIn" data-es="Leer en LinkedIn">
            Read on LinkedIn
          </a>
        )}
      </div>
    </article>
  ) : type === 'creative' || type === 'riddle' ? (
    <article class="card card-creative reveal" data-type={type}>
      {article.image && (
        <div class="card-image">
          <img src={article.image} alt={article.title} loading="lazy" decoding="async" />
          {article.imageAttribution && (
            <span class="card-attribution">{article.imageAttribution}</span>
          )}
        </div>
      )}
      <div class="card-body">
        <span class="card-badge card-badge--creative" data-en={label.en} data-es={label.es}>{label.en}</span>
        <h3 class="card-title">{article.title}</h3>
        <p class="card-teaser card-teaser--creative">{article.teaser}</p>
        <div class="card-meta">
          <span class="card-date">{date}</span>
          <span class="card-readtime">
            {article.readTime}{' '}
            <span data-en="min read" data-es="min de lectura">min read</span>
          </span>
          {article.linkedinUrl && (
            <a href={article.linkedinUrl} target="_blank" rel="noopener noreferrer" class="card-link" data-en="Read on LinkedIn" data-es="Leer en LinkedIn">
              Read on LinkedIn
            </a>
          )}
        </div>
      </div>
    </article>
  ) : (
    <article
      class:list={[
        'card',
        'card-standard',
        'reveal',
        { 'card-featured': featured, 'card-has-image': !!article.image },
      ]}
      data-type={type}
    >
      {article.image && (
        <div class="card-image">
          <img
            src={article.image}
            alt={article.title}
            loading={featured ? 'eager' : 'lazy'}
            decoding="async"
          />
          {article.imageAttribution && (
            <span class="card-attribution">{article.imageAttribution}</span>
          )}
        </div>
      )}
      <div class="card-body">
        <span class="card-badge card-badge--article" data-en={label.en} data-es={label.es}>{label.en}</span>
        <h3 class="card-title">{article.title}</h3>
        <p class="card-teaser">{article.teaser}</p>
        <div class="card-meta">
          <span class="card-date">{date}</span>
          <span class="card-readtime">
            {article.readTime}{' '}
            <span data-en="min read" data-es="min de lectura">
              min read
            </span>
          </span>
          {article.linkedinUrl && (
            <a
              href={article.linkedinUrl}
              target="_blank"
              rel="noopener noreferrer"
              class="card-link"
              data-en="Read on LinkedIn"
              data-es="Leer en LinkedIn"
            >
              Read on LinkedIn
            </a>
          )}
        </div>
      </div>
    </article>
  )
}

<style>
  .card {
    background: var(--color-surface);
    border: 1px solid var(--color-arena);
    border-radius: var(--radius-card);
    overflow: hidden;
    transition:
      transform var(--duration-base) var(--ease-spring),
      box-shadow var(--duration-base) var(--ease-spring),
      border-color var(--duration-base) var(--ease-spring);
    animation: cardIn 0.45s var(--ease-spring) both;
    animation-delay: calc(var(--card-index, 0) * var(--stagger));
    position: relative;
  }

  .card:hover {
    transform: translateY(-4px);
    box-shadow: 0 12px 28px rgba(31, 36, 33, 0.08);
    border-color: var(--color-jade);
  }

  /* Universal badge */
  .card-badge {
    display: inline-block;
    font-family: var(--font-mono);
    font-size: 10px;
    font-weight: 600;
    letter-spacing: 1.2px;
    text-transform: uppercase;
    padding: 4px 9px;
    border-radius: var(--radius-pill);
    margin-bottom: 0.6rem;
  }

  .card-badge--article    { color: var(--color-jade-deep);     background: var(--color-jade-soft); }
  .card-badge--question   { color: var(--color-carbon);        background: var(--color-arena); }
  .card-badge--take       { color: var(--color-carbon);        background: var(--color-terracota-soft); }
  .card-badge--imagequote { color: var(--color-carbon);        background: var(--color-maiz); }
  .card-badge--tip        { color: var(--color-jade-deep);     background: var(--color-jade-soft); }
  .card-badge--creative   {
    color: #FFFFFF;
    background: linear-gradient(90deg, var(--color-jade) 0%, var(--color-terracota) 100%);
  }

  /* Standard card */
  .card-standard .card-body {
    padding: var(--space-md);
  }

  .card-image {
    position: relative;
    aspect-ratio: 16 / 10;
    overflow: hidden;
  }

  .card-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.6s var(--ease-spring);
  }

  .card:hover .card-image img {
    transform: scale(1.04);
  }

  .card-attribution {
    position: absolute;
    bottom: 0.5rem;
    right: 0.5rem;
    font-size: var(--text-xs);
    color: rgba(255, 255, 255, 0.78);
    background: rgba(31, 36, 33, 0.55);
    padding: 2px 6px;
    border-radius: 4px;
  }

  .card-title {
    font-family: var(--font-display);
    font-size: 1.25rem;
    font-weight: 600;
    line-height: 1.25;
    letter-spacing: -0.01em;
    color: var(--color-carbon);
    margin-bottom: var(--space-xs);
  }

  .card-teaser {
    font-family: var(--font-body);
    font-size: 0.9375rem;
    color: var(--color-carbon-soft);
    line-height: 1.6;
    margin-bottom: var(--space-sm);
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .card-meta {
    display: flex;
    align-items: center;
    gap: var(--space-sm);
    font-size: var(--text-xs);
    color: var(--color-carbon-soft);
  }

  .card-meta--padded { padding: var(--space-md); padding-top: 0.75rem; }

  .card-link {
    margin-left: auto;
    font-weight: 600;
    color: var(--color-jade-deep);
  }

  /* Featured card */
  .card-featured { grid-column: span 2; }
  .card-featured .card-image { aspect-ratio: 2 / 1; }
  .card-featured .card-title { font-size: 1.625rem; }

  /* Question card — no image, large italic Fraunces pull-quote, terracota quote mark */
  .card-question {
    padding: var(--space-md) var(--space-md) var(--space-sm);
  }

  .card-question .question-text {
    font-family: var(--font-display);
    font-style: italic;
    font-size: clamp(1.25rem, 2.4vw, 1.625rem);
    font-weight: 500;
    line-height: 1.3;
    color: var(--color-carbon);
    margin: 0.25rem 0 var(--space-md);
    position: relative;
    padding-left: 2.5rem;
  }

  .card-question .question-text::before {
    content: '"';
    position: absolute;
    left: 0;
    top: -0.45em;
    font-family: var(--font-display);
    font-style: normal;
    font-size: 4.5rem;
    color: var(--color-terracota);
    line-height: 1;
  }

  .card-question .question-text p { margin: 0; }
  .card-question .card-meta { padding: 0 0 var(--space-sm); }

  /* Take card — diagonal jade ribbon top-right, subtle rotate */
  .card-take {
    background: var(--color-surface);
    border-radius: var(--radius-card);
    overflow: hidden;
    transform: rotate(-0.4deg);
  }
  .card-take:hover { transform: translateY(-4px) rotate(-0.4deg); }

  .card-ribbon {
    position: absolute;
    top: 14px;
    right: -38px;
    width: 130px;
    transform: rotate(38deg);
    background: var(--color-jade);
    color: #FFFFFF;
    text-align: center;
    z-index: 2;
    box-shadow: 0 2px 6px rgba(31, 36, 33, 0.18);
    padding: 4px 0;
  }

  .card-ribbon-text {
    font-family: var(--font-mono);
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 1.5px;
    text-transform: uppercase;
  }

  .take-content { padding: var(--space-md); }
  .card-take .card-meta { padding: 0 var(--space-md) var(--space-md); }

  /* Image-quote card — image-first with overlay scrim + bottom-positioned quote */
  .card-imagequote { padding: 0; }
  .card-image--full {
    aspect-ratio: 4 / 3;
    position: relative;
  }
  .card-image-scrim {
    position: absolute;
    inset: 0;
    background: linear-gradient(to bottom, transparent 35%, rgba(31, 36, 33, 0.80) 100%);
  }
  .card-image-quote {
    position: absolute;
    left: 0;
    right: 0;
    bottom: 0;
    padding: var(--space-md);
    color: #FFFFFF;
  }
  .imagequote-title {
    font-family: var(--font-display);
    font-style: italic;
    font-size: 1.25rem;
    font-weight: 500;
    line-height: 1.3;
    margin: 0;
    color: #FFFFFF;
  }
  .card-imagequote .card-badge--imagequote { color: var(--color-carbon); }

  /* Tip card — compact, no image, numbered hash */
  .card-tip { padding: var(--space-md); }
  .tip-content { display: flex; flex-direction: column; gap: 0.5rem; margin-bottom: var(--space-sm); }
  .tip-title {
    font-family: var(--font-display);
    font-size: 1.125rem;
    color: var(--color-carbon);
    display: flex;
    align-items: baseline;
    gap: 0.4rem;
  }
  .tip-number {
    font-family: var(--font-mono);
    font-size: 1.25rem;
    font-weight: 700;
    color: var(--color-jade);
  }

  /* Creative card — gradient badge, hover reveals fuller teaser */
  .card-creative .card-body { padding: var(--space-md); }
  .card-teaser--creative {
    transition: -webkit-line-clamp var(--duration-base) var(--ease-spring);
  }
  .card-creative:hover .card-teaser--creative {
    -webkit-line-clamp: 5;
  }

  @media (max-width: 640px) {
    .card-featured { grid-column: span 1; }
    .card-featured .card-image { aspect-ratio: 16 / 10; }
  }
</style>
