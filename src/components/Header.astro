---
const currentPath = Astro.url.pathname;
---

<header class="site-header">
  <div class="header-inner">
    <a href="/" class="logo" aria-label="JufipAI Home">
      <svg class="logo-glyph" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 32 32" width="28" height="28" aria-hidden="true">
        <defs>
          <linearGradient id="catGradHeader" x1="0%" y1="0%" x2="100%" y2="100%">
            <stop offset="0%" stop-color="#0E7C66"/>
            <stop offset="100%" stop-color="#08503F"/>
          </linearGradient>
        </defs>
        <path d="M8 12 L8 8 L10 8 L12 10 L20 10 L22 8 L24 8 L24 12 L22 14 L22 22 L20 24 L12 24 L10 22 L10 14 Z" fill="none" stroke="url(#catGradHeader)" stroke-width="1.5"/>
        <path d="M8 12 L10 8 L12 10" fill="none" stroke="url(#catGradHeader)" stroke-width="1.5"/>
        <path d="M20 10 L22 8 L24 12" fill="none" stroke="url(#catGradHeader)" stroke-width="1.5"/>
        <circle cx="13" cy="15" r="1.5" fill="url(#catGradHeader)"/>
        <circle cx="19" cy="15" r="3" fill="#0E7C66" opacity="0.3"/>
        <path d="M19 13 L19 17 M17 15 L19 13 L21 15 M17 17 L19 15 L21 17" stroke="url(#catGradHeader)" stroke-width="1" fill="none"/>
        <path d="M16 18 L15 20 L17 20 Z" fill="url(#catGradHeader)"/>
        <path d="M16 20 Q14 22 12 21 M16 20 Q18 22 20 21" fill="none" stroke="url(#catGradHeader)" stroke-width="1"/>
      </svg>
      <span class="logo-text">JufipAI</span>
    </a>

    <nav class="site-nav" aria-label="Main navigation">
      <a
        href="/writing"
        class:list={[{ active: currentPath.startsWith('/writing') }]}
        data-en="Writing"
        data-es="Escritos">Writing</a
      >
      <a
        href="/about"
        class:list={[{ active: currentPath.startsWith('/about') }]}
        data-en="About"
        data-es="Acerca">About</a
      >
      <a
        href="/contact"
        class:list={[{ active: currentPath.startsWith('/contact') }]}
        data-en="Contact"
        data-es="Contacto">Contact</a
      >
    </nav>

    <div class="header-right">
      <button
        type="button"
        class="header-subscribe"
        id="header-subscribe-btn"
        data-en="Subscribe"
        data-es="Suscribirme"
      >
        Suscribirme
      </button>
      <div class="lang-toggle" aria-label="Language selector">
        <button data-lang="en" class="active" aria-label="English">EN</button>
        <button data-lang="es" aria-label="Espanol">ES</button>
      </div>
    </div>
  </div>
</header>

<script>
  function wireSubscribeButton() {
    const btn = document.getElementById('header-subscribe-btn');
    if (!btn) return;
    btn.addEventListener('click', () => {
      const fn = (window as unknown as { jufipaiOpenNewsletter?: () => void }).jufipaiOpenNewsletter;
      if (typeof fn === 'function') fn();
    });
  }
  wireSubscribeButton();
  document.addEventListener('astro:after-swap', wireSubscribeButton);
</script>

<style>
  .site-header {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 100;
    background: rgba(31, 36, 33, 0.92);
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
    border-bottom: 1px solid rgba(14, 124, 102, 0.20);
    height: var(--nav-height);
  }

  .header-right {
    display: flex;
    align-items: center;
    gap: var(--space-sm);
  }

  .header-subscribe {
    font-family: var(--font-body);
    font-size: var(--text-small);
    font-weight: 600;
    color: #FFFFFF;
    background: var(--color-jade);
    border: none;
    padding: 0.5rem 1rem;
    border-radius: var(--radius-pill);
    cursor: pointer;
    transition: background var(--duration) var(--ease), transform var(--duration) var(--ease);
  }

  .header-subscribe:hover {
    background: var(--color-jade-deep);
    transform: translateY(-1px);
  }

  .header-subscribe:focus-visible {
    outline: 2px solid var(--color-maiz);
    outline-offset: 2px;
  }

  .header-inner {
    max-width: var(--max-width);
    margin: 0 auto;
    padding: 0 var(--space-md);
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-lg);
  }

  .logo {
    text-decoration: none;
    color: var(--text-on-dark);
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
  }

  .logo-glyph {
    display: block;
    flex-shrink: 0;
    animation: logoEnter 320ms cubic-bezier(0.34, 1.56, 0.64, 1) both;
  }

  @keyframes logoEnter {
    from { opacity: 0; transform: scale(0.92); }
    to   { opacity: 1; transform: scale(1); }
  }

  .logo-text {
    font-family: var(--font-mono);
    font-size: var(--text-small);
    font-weight: 400;
    letter-spacing: 0.05em;
    text-transform: uppercase;
  }

  @media (prefers-reduced-motion: reduce) {
    .logo-glyph { animation: none; }
  }

  .site-nav {
    display: flex;
    gap: var(--space-lg);
  }

  .site-nav a {
    font-size: var(--text-small);
    font-weight: 500;
    color: var(--text-on-dark-muted);
    text-decoration: none;
    transition: color var(--duration) var(--ease);
    position: relative;
  }

  .site-nav a:hover,
  .site-nav a.active {
    color: var(--text-on-dark);
  }

  .site-nav a.active::after {
    content: '';
    position: absolute;
    bottom: -2px;
    left: 0;
    right: 0;
    height: 1.5px;
    background: var(--color-terracota);
  }

  .lang-toggle {
    display: flex;
    gap: 2px;
    background: rgba(255, 255, 255, 0.08);
    border-radius: 6px;
    padding: 2px;
  }

  .lang-toggle button {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    padding: 4px 8px;
    border: none;
    background: none;
    color: var(--text-on-dark-muted);
    cursor: pointer;
    border-radius: 4px;
    transition: all var(--duration) var(--ease);
  }

  .lang-toggle button.active {
    background: rgba(14, 124, 102, 0.25);
    color: var(--text-on-dark);
  }

  @media (max-width: 640px) {
    .header-inner {
      flex-wrap: wrap;
      height: auto;
      padding: var(--space-sm) var(--space-md);
      gap: var(--space-sm);
    }

    .site-nav {
      order: 3;
      width: 100%;
      justify-content: center;
      gap: var(--space-md);
    }

    .header-subscribe {
      padding: 0.4rem 0.85rem;
      font-size: var(--text-xs);
    }
  }
</style>
