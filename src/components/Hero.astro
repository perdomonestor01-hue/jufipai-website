---
interface Props {
  headline?: string;
  headlineEs?: string;
  sub?: string;
  subEs?: string;
  ctaText?: string;
  ctaTextEs?: string;
  ctaHref?: string;
}

const {
  headline = 'automation for people who hate spreadsheets',
  headlineEs = 'automatizacion para gente que odia las hojas de calculo',
  sub = 'Custom AI and automation for small teams. Real systems, not drag-and-drop toys.',
  subEs = 'IA y automatizacion para equipos pequenos. Sistemas reales, no juguetes.',
  ctaText = 'Read the latest',
  ctaTextEs = 'Lee lo ultimo',
  ctaHref = '/writing',
} = Astro.props;
---

<section class="hero">
  <div class="hero-inner">
    <h1 class="hero-headline" data-en={headline} data-es={headlineEs}>
      {headline}
    </h1>
    <p class="hero-sub" data-en={sub} data-es={subEs}>
      {sub}
    </p>
    <div class="hero-actions">
      <a href={ctaHref} class="hero-cta" data-en={ctaText} data-es={ctaTextEs}>
        {ctaText} <span class="arrow">&rarr;</span>
      </a>
      <a href="/contact" class="hero-pill" data-en="Get in touch" data-es="Escribenos">
        Get in touch
      </a>
    </div>
  </div>
</section>

<style>
  .hero {
    padding: calc(var(--nav-height) + var(--space-2xl)) 0 var(--space-xl);
  }

  .hero-inner {
    max-width: var(--max-width);
    margin: 0 auto;
    padding: 0 var(--space-md);
    border-left: 3px solid var(--accent);
    padding-left: var(--space-md);
  }

  .hero-headline {
    font-family: var(--font-display);
    font-size: var(--text-display);
    font-weight: 400;
    line-height: 1.1;
    color: var(--text-primary);
    margin-bottom: var(--space-md);
    max-width: 42rem;
  }

  .hero-sub {
    font-size: 1.125rem;
    color: var(--text-muted);
    line-height: 1.6;
    margin-bottom: var(--space-lg);
    max-width: 36rem;
  }

  .hero-cta {
    font-family: var(--font-body);
    font-size: var(--text-body-size);
    font-weight: 500;
    color: var(--accent);
    text-decoration: none;
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    transition: gap var(--duration) var(--ease);
  }

  .hero-cta:hover {
    color: var(--accent-dark);
    gap: 0.75rem;
  }

  .arrow {
    transition: transform var(--duration) var(--ease);
  }

  .hero-cta:hover .arrow {
    transform: translateX(2px);
  }

  .hero-actions {
    display: flex;
    align-items: center;
    gap: var(--space-md);
  }

  .hero-pill {
    font-size: var(--text-small);
    font-weight: 500;
    color: var(--accent);
    border: 1.5px solid var(--accent);
    padding: 0.5rem 1.25rem;
    border-radius: 100px;
    text-decoration: none;
    transition: background var(--duration) var(--ease), color var(--duration) var(--ease);
  }

  .hero-pill:hover {
    background: var(--accent);
    color: var(--white);
  }

  @media (max-width: 640px) {
    .hero-actions {
      flex-wrap: wrap;
    }
  }
</style>
