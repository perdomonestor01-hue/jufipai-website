---
const year = new Date().getFullYear();
---

<footer class="site-footer">
  <div class="footer-inner">
    <div class="footer-left">
      <span class="footer-logo-wrap">
        <svg class="footer-glyph" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 32 32" width="24" height="24" aria-hidden="true">
          <defs>
            <linearGradient id="catGradFooter" x1="0%" y1="0%" x2="100%" y2="100%">
              <stop offset="0%" stop-color="#0E7C66"/>
              <stop offset="100%" stop-color="#08503F"/>
            </linearGradient>
          </defs>
          <path d="M8 12 L8 8 L10 8 L12 10 L20 10 L22 8 L24 8 L24 12 L22 14 L22 22 L20 24 L12 24 L10 22 L10 14 Z" fill="none" stroke="url(#catGradFooter)" stroke-width="1.5"/>
          <path d="M8 12 L10 8 L12 10" fill="none" stroke="url(#catGradFooter)" stroke-width="1.5"/>
          <path d="M20 10 L22 8 L24 12" fill="none" stroke="url(#catGradFooter)" stroke-width="1.5"/>
          <circle cx="13" cy="15" r="1.5" fill="url(#catGradFooter)"/>
          <circle cx="19" cy="15" r="3" fill="#0E7C66" opacity="0.3"/>
          <path d="M19 13 L19 17 M17 15 L19 13 L21 15 M17 17 L19 15 L21 17" stroke="url(#catGradFooter)" stroke-width="1" fill="none"/>
          <path d="M16 18 L15 20 L17 20 Z" fill="url(#catGradFooter)"/>
          <path d="M16 20 Q14 22 12 21 M16 20 Q18 22 20 21" fill="none" stroke="url(#catGradFooter)" stroke-width="1"/>
        </svg>
        <span class="footer-logo">JufipAI</span>
      </span>
      <span
        class="footer-location"
        data-en="Built in Dallas, TX"
        data-es="Hecho en Dallas, TX">Built in Dallas, TX</span
      >
    </div>
    <div class="footer-right">
      <a
        href="https://www.linkedin.com/company/jufipai"
        target="_blank"
        rel="noopener noreferrer"
      >LinkedIn</a>
      <a
        href="/contact"
        data-en="Get in touch"
        data-es="Contactanos"
      >Get in touch</a>
      <span class="footer-copy">&copy; {year}</span>
    </div>
  </div>
</footer>

<style>
  .site-footer {
    margin-top: var(--space-2xl);
    padding: var(--space-xl) 0;
    background: var(--bg-dark);
    border-top: 1px solid rgba(14, 124, 102, 0.20);
  }

  .footer-inner {
    max-width: var(--max-width);
    margin: 0 auto;
    padding: 0 var(--space-md);
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: var(--space-md);
  }

  .footer-left,
  .footer-right {
    display: flex;
    align-items: center;
    gap: var(--space-md);
  }

  .footer-logo-wrap {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
  }

  .footer-glyph {
    display: block;
    flex-shrink: 0;
  }

  .footer-logo {
    font-family: var(--font-mono);
    font-size: var(--text-small);
    color: var(--text-on-dark);
    letter-spacing: 0.05em;
    text-transform: uppercase;
  }

  .footer-location {
    font-size: var(--text-small);
    color: var(--text-on-dark-muted);
  }

  .footer-right a {
    font-size: var(--text-small);
    color: var(--color-terracota);
    transition: color var(--duration) var(--ease);
  }

  .footer-right a:hover {
    color: var(--color-maiz);
  }

  .footer-copy {
    font-size: var(--text-xs);
    color: var(--text-on-dark-muted);
  }

  @media (max-width: 640px) {
    .footer-inner {
      flex-direction: column;
      text-align: center;
    }
  }
</style>
