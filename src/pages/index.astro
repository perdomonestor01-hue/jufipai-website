---
import Base from '../layouts/Base.astro';
import Hero from '../components/Hero.astro';
import ContentCard from '../components/ContentCard.astro';
import IndustryInsightQuiz from '../components/IndustryInsightQuiz.astro';
import { fetchArticles } from '../lib/api';

const articles = await fetchArticles();
const featuredArticle = articles.find(a => a.image) || articles[0];
const remainingArticles = articles.filter(a => a.id !== featuredArticle?.id).slice(0, 8);

const services = [
  {
    title: 'Marketing Campaign Automation',
    titleEs: 'Automatizacion de Campanas',
    desc: 'Multi-channel campaigns that run themselves. Scheduling, content, and analytics — connected end to end.',
    descEs: 'Campanas multicanal que se ejecutan solas. Agenda, contenido y analisis — conectados de principio a fin.',
    stat: 'Always-on reach',
    statEs: 'Alcance continuo',
  },
  {
    title: 'Digital Time Clocks',
    titleEs: 'Relojes Digitales',
    desc: 'Kiosk or mobile clock-in systems. Accurate hours, instant audit trails, payroll-ready exports.',
    descEs: 'Sistemas de entrada por kiosko o movil. Horas precisas, auditoria instantanea, listos para nomina.',
    stat: 'Zero paper timesheets',
    statEs: 'Cero hojas en papel',
  },
  {
    title: 'Job Portals',
    titleEs: 'Portales de Empleo',
    desc: 'Branded job boards with automated posting, applicant tracking, and candidate communication.',
    descEs: 'Portales de empleo personalizados con publicacion automatica, seguimiento y comunicacion.',
    stat: 'One-click posting',
    statEs: 'Publicacion en un clic',
  },
  {
    title: 'Application Process',
    titleEs: 'Procesos de Aplicacion',
    desc: 'End-to-end applicant flows. Forms, screens, notifications, and handoffs run without you watching.',
    descEs: 'Flujos completos de aplicacion. Formularios, filtros, notificaciones y transferencias automaticas.',
    stat: 'Hours to minutes',
    statEs: 'De horas a minutos',
  },
  {
    title: 'ID & Background Screening',
    titleEs: 'Verificacion y Antecedentes',
    desc: 'Automated identity verification and background check pipelines. Compliance built in from day one.',
    descEs: 'Verificacion automatica de identidad y antecedentes. Cumplimiento integrado desde el primer dia.',
    stat: 'Same-day clearance',
    statEs: 'Aprobacion el mismo dia',
  },
  {
    title: 'AI Resume Analyzer',
    titleEs: 'Analizador de CV con IA',
    desc: 'Score, rank, and shortlist resumes instantly. Your criteria, your format, consistent every time.',
    descEs: 'Evalua, clasifica y selecciona CVs al instante. Tu criterio, tu formato, consistente cada vez.',
    stat: 'Seconds per resume',
    statEs: 'Segundos por CV',
  },
];

const stats = [
  { number: '40+', label: 'Automations built', labelEs: 'Automatizaciones creadas' },
  { number: '10k+', label: 'Hours saved yearly', labelEs: 'Horas ahorradas al ano' },
  { number: '< 2hr', label: 'Avg setup time', labelEs: 'Tiempo promedio de setup' },
];

const industries = [
  { en: 'Staffing & Recruiting', es: 'Reclutamiento y Personal' },
  { en: 'Construction Safety', es: 'Seguridad en Construccion' },
  { en: 'Property Management', es: 'Administracion de Propiedades' },
  { en: 'Real Estate', es: 'Bienes Raices' },
  { en: 'Professional Services', es: 'Servicios Profesionales' },
];
---

<Base
  title="Home"
  description="Custom AI and automation for small teams. Real systems, not drag-and-drop toys."
>
  <Hero />

  <IndustryInsightQuiz />

  <!-- Bento — capability teasers (marketing tiles, not functional routes) -->
  <section class="bento-section">
    <div class="bento-inner">
      <div class="bento-grid-bento">
        <a class="bento-tile bento-tile--chat" href="/contact">
          <span class="bento-icon" aria-hidden="true">
            <svg viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>
          </span>
          <h3 class="bento-title" data-en="AI Chat" data-es="Chat IA">Chat IA</h3>
          <p class="bento-sub" data-en="Ask. Get an answer that fits your business." data-es="Pregunta. Recibe una respuesta que encaja con tu negocio.">Pregunta. Recibe una respuesta que encaja con tu negocio.</p>
        </a>

        <a class="bento-tile bento-tile--invoice" href="/contact">
          <span class="bento-icon" aria-hidden="true">
            <svg viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="8" y1="13" x2="16" y2="13"/><line x1="8" y1="17" x2="13" y2="17"/></svg>
          </span>
          <h3 class="bento-title" data-en="Invoices" data-es="Facturas">Facturas</h3>
          <p class="bento-sub" data-en="Recurring, branded, tracked." data-es="Recurrentes, con tu marca, con seguimiento.">Recurrentes, con tu marca, con seguimiento.</p>
        </a>

        <a class="bento-tile bento-tile--quote" href="/contact">
          <span class="bento-icon" aria-hidden="true">
            <svg viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
          </span>
          <h3 class="bento-title" data-en="Quotes" data-es="Cotizaciones">Cotizaciones</h3>
          <p class="bento-sub" data-en="Send in minutes. Close more." data-es="Envíalas en minutos. Cierra más.">Envíalas en minutos. Cierra más.</p>
        </a>

        <a class="bento-tile bento-tile--expenses" href="/contact">
          <span class="bento-icon" aria-hidden="true">
            <svg viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="1" x2="12" y2="23"/><path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/></svg>
          </span>
          <h3 class="bento-title" data-en="Expenses" data-es="Gastos">Gastos</h3>
          <p class="bento-sub" data-en="Photo a receipt. Done." data-es="Foto al recibo. Listo.">Foto al recibo. Listo.</p>
        </a>

        <a class="bento-tile bento-tile--blog" href="/writing">
          <span class="bento-icon" aria-hidden="true">
            <svg viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"/><path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z"/></svg>
          </span>
          <h3 class="bento-title" data-en="Writing" data-es="Blog">Blog</h3>
          <p class="bento-sub" data-en="Ideas, takes, and tips for your business." data-es="Ideas, opiniones y consejos para tu negocio.">Ideas, opiniones y consejos para tu negocio.</p>
        </a>

        <button type="button" class="bento-tile bento-tile--your-biz" id="bento-newsletter-trigger">
          <span class="bento-icon" aria-hidden="true">
            <svg viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
          </span>
          <h3 class="bento-title" data-en="Your business →" data-es="Tu negocio →">Tu negocio &rarr;</h3>
          <p class="bento-sub" data-en="Get the next one before everyone else." data-es="Recibe el próximo antes que nadie.">Recibe el próximo antes que nadie.</p>
        </button>
      </div>
    </div>
  </section>

  <!-- Stats bar -->
  <section class="stats-bar">
    <div class="stats-inner">
      {stats.map(s => (
        <div class="stat-item">
          <span class="stat-number">{s.number}</span>
          <span class="stat-label" data-en={s.label} data-es={s.labelEs}>{s.label}</span>
        </div>
      ))}
    </div>
  </section>

  <!-- Featured post -->
  {featuredArticle && (
    <section class="featured-section">
      <div class="featured-inner">
        <span class="section-label label-style" data-en="Latest" data-es="Reciente">Latest</span>
        <a href={featuredArticle.linkedinUrl || '/writing'} target={featuredArticle.linkedinUrl ? '_blank' : '_self'} rel="noopener noreferrer" class="featured-card reveal">
          {featuredArticle.image && (
            <div class="featured-image">
              <img src={featuredArticle.image} alt={featuredArticle.title} loading="eager" decoding="async" />
            </div>
          )}
          <div class="featured-body">
            <h2 class="featured-title">{featuredArticle.title}</h2>
            <p class="featured-teaser">{featuredArticle.teaser}</p>
            <div class="featured-meta">
              <span>{new Date(featuredArticle.createdAt).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' })}</span>
              <span>{featuredArticle.readTime} min read</span>
              <span class="featured-cta" data-en="Read on LinkedIn" data-es="Leer en LinkedIn">Read on LinkedIn <span aria-hidden="true">&rarr;</span></span>
            </div>
          </div>
        </a>
      </div>
    </section>
  )}

  <!-- Services -->
  <section class="services-section">
    <div class="services-inner">
      <span class="section-label label-style" data-en="Catalog" data-es="Catalogo">Catalog</span>
      <h2 class="services-headline" data-en="More with less. Stop wasting time." data-es="Mas con menos. Deja de perder tiempo.">More with less. Stop wasting time.</h2>
      <p class="services-intro" data-en="Six systems we build and operate. Pick the one that maps to your bottleneck — or combine them." data-es="Seis sistemas que construimos y operamos. Elige el que corresponda a tu cuello de botella — o combinalos.">Six systems we build and operate. Pick the one that maps to your bottleneck — or combine them.</p>
      <div class="services-grid">
        {services.map(s => (
          <div class="service-card reveal">
            <h3 data-en={s.title} data-es={s.titleEs}>{s.title}</h3>
            <p data-en={s.desc} data-es={s.descEs}>{s.desc}</p>
            <span class="service-stat" data-en={s.stat} data-es={s.statEs}>{s.stat}</span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Content feed -->
  {remainingArticles.length > 0 && (
    <section class="content-feed">
      <div class="feed-inner">
        <div class="feed-header">
          <span class="section-label label-style" data-en="More from JufipAI" data-es="Mas de JufipAI">More from JufipAI</span>
          <a href="/writing" class="feed-all" data-en="View all" data-es="Ver todo">View all <span aria-hidden="true">&rarr;</span></a>
        </div>
        <div class="bento-grid">
          {remainingArticles.map((article, i) => (
            <div style={`--card-index: ${i}`}>
              <ContentCard article={article} />
            </div>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- Industries -->
  <section class="industries reveal">
    <div class="industries-inner">
      <h2
        class="industries-label"
        data-en="Industries we work with"
        data-es="Industrias con las que trabajamos"
      >
        Industries we work with
      </h2>
      <div class="industries-list">
        {industries.map(ind => (
          <span class="industry-tag" data-en={ind.en} data-es={ind.es}>{ind.en}</span>
        ))}
      </div>
    </div>
  </section>

  <script>
    function wireBentoNewsletter() {
      const btn = document.getElementById('bento-newsletter-trigger');
      if (!btn) return;
      btn.addEventListener('click', () => {
        const fn = (window as unknown as { jufipaiOpenNewsletter?: () => void }).jufipaiOpenNewsletter;
        if (typeof fn === 'function') fn();
      });
    }
    wireBentoNewsletter();
    document.addEventListener('astro:after-swap', wireBentoNewsletter);
  </script>

  <!-- CTA -->
  <section class="bottom-cta reveal">
    <div class="cta-inner">
      <div class="cta-text">
        <p class="cta-headline" data-en="Stop doing the boring stuff." data-es="Deja de hacer lo aburrido.">
          Stop doing the boring stuff.
        </p>
        <p class="cta-sub" data-en="Tell us the process. We make it disappear." data-es="Cuentanos el proceso. Lo hacemos desaparecer.">
          Tell us the process. We make it disappear.
        </p>
      </div>
      <div class="cta-actions">
        <a href="/contact" class="cta-btn" data-en="Let's talk" data-es="Hablemos">Let's talk</a>
        <a href="https://calendly.com/contact-jufipai/30min" target="_blank" rel="noopener noreferrer" class="cta-link" data-en="Book a call" data-es="Agendar llamada">Book a call <span aria-hidden="true">&nearr;</span></a>
      </div>
    </div>
  </section>
</Base>

<style>
  /* Bento — capability teasers */
  .bento-section {
    padding: var(--space-xl) 0 var(--space-lg);
    background: var(--color-papel);
  }

  .bento-inner {
    max-width: var(--max-width);
    margin: 0 auto;
    padding: 0 var(--space-md);
  }

  .bento-grid-bento {
    display: grid;
    grid-template-columns: repeat(12, 1fr);
    grid-auto-rows: minmax(160px, auto);
    gap: var(--space-md);
  }

  .bento-tile {
    position: relative;
    background: var(--color-surface);
    border: 1px solid var(--color-arena);
    border-radius: var(--radius-card);
    padding: var(--space-md);
    text-decoration: none;
    color: var(--color-carbon);
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    transition: transform var(--duration-base) var(--ease-spring), box-shadow var(--duration-base) var(--ease-spring), border-color var(--duration-base) var(--ease-spring);
    cursor: pointer;
    text-align: left;
    font-family: var(--font-body);
  }

  .bento-tile:hover {
    transform: translateY(-4px);
    box-shadow: 0 12px 28px rgba(31, 36, 33, 0.08);
    border-color: var(--color-jade);
    color: var(--color-carbon);
  }

  .bento-tile:focus-visible {
    outline: 2px solid var(--color-jade);
    outline-offset: 3px;
  }

  .bento-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 36px;
    height: 36px;
    border-radius: var(--radius-pill);
    background: var(--color-jade-soft);
    color: var(--color-jade-deep);
  }

  .bento-title {
    font-family: var(--font-display);
    font-size: 1.25rem;
    font-weight: 600;
    letter-spacing: -0.01em;
    color: var(--color-carbon);
    margin: 0.25rem 0 0;
  }

  .bento-sub {
    font-size: 0.9375rem;
    line-height: 1.5;
    color: var(--color-carbon-soft);
    margin: 0;
  }

  /* Asymmetric layout — large feature tile + supporting tiles. */
  .bento-tile--chat       { grid-column: span 6; grid-row: span 2; }
  .bento-tile--invoice    { grid-column: span 3; }
  .bento-tile--quote      { grid-column: span 3; }
  .bento-tile--expenses   { grid-column: span 3; }
  .bento-tile--blog       { grid-column: span 3; }
  .bento-tile--your-biz   { grid-column: span 6; background: var(--color-jade); color: #FFFFFF; border-color: var(--color-jade); }
  .bento-tile--your-biz:hover { background: var(--color-jade-deep); border-color: var(--color-jade-deep); color: #FFFFFF; }
  .bento-tile--your-biz .bento-title { color: #FFFFFF; }
  .bento-tile--your-biz .bento-sub { color: rgba(255,255,255,0.85); }
  .bento-tile--your-biz .bento-icon { background: rgba(255,255,255,0.15); color: #FFFFFF; }

  .bento-tile--chat .bento-title { font-size: 2rem; }
  .bento-tile--chat .bento-sub { font-size: 1.05rem; max-width: 38ch; }

  /* Stats bar */
  .stats-bar {
    background: var(--color-carbon);
    border-bottom: 1px solid rgba(14, 124, 102, 0.18);
    margin-top: -1px;
  }

  .stats-inner {
    max-width: var(--max-width);
    margin: 0 auto;
    padding: var(--space-lg) var(--space-md);
    display: flex;
    justify-content: center;
    gap: var(--space-2xl);
  }

  .stat-item {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.25rem;
  }

  .stat-number {
    font-family: var(--font-display);
    font-size: clamp(1.5rem, 3vw, 2rem);
    font-weight: 600;
    color: var(--color-maiz);
  }

  .stat-label {
    font-size: var(--text-xs);
    color: var(--text-on-dark-muted);
    text-transform: uppercase;
    letter-spacing: 0.5px;
  }

  /* Section label */
  .section-label {
    display: block;
    margin-bottom: var(--space-md);
  }

  /* Featured post */
  .featured-section {
    padding: var(--space-xl) 0;
  }

  .featured-inner {
    max-width: var(--max-width);
    margin: 0 auto;
    padding: 0 var(--space-md);
  }

  .featured-card {
    display: grid;
    grid-template-columns: 1.2fr 1fr;
    background: var(--white);
    border: 1px solid var(--border-subtle);
    border-radius: 12px;
    overflow: hidden;
    text-decoration: none;
    color: inherit;
    transition: transform var(--duration) var(--ease), box-shadow var(--duration) var(--ease);
  }

  .featured-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 12px 32px rgba(15, 20, 25, 0.1);
    color: inherit;
  }

  .featured-image {
    aspect-ratio: 16 / 10;
    overflow: hidden;
  }

  .featured-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.6s var(--ease);
  }

  .featured-card:hover .featured-image img {
    transform: scale(1.04);
  }

  .featured-body {
    padding: var(--space-lg);
    display: flex;
    flex-direction: column;
    justify-content: center;
  }

  .featured-title {
    font-family: var(--font-display);
    font-size: clamp(1.25rem, 2.5vw, 1.625rem);
    font-weight: 700;
    line-height: 1.3;
    color: var(--text-primary);
    margin-bottom: var(--space-sm);
  }

  .featured-teaser {
    font-size: var(--text-small);
    color: var(--text-muted);
    line-height: 1.6;
    margin-bottom: var(--space-md);
    display: -webkit-box;
    -webkit-line-clamp: 4;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .featured-meta {
    display: flex;
    align-items: center;
    gap: var(--space-sm);
    font-size: var(--text-xs);
    color: var(--text-muted);
  }

  .featured-cta {
    margin-left: auto;
    color: var(--accent-text);
    font-weight: 500;
  }

  /* Services */
  .services-section {
    padding: var(--space-xl) 0;
    background: var(--bg-primary);
  }

  .services-inner {
    max-width: var(--max-width);
    margin: 0 auto;
    padding: 0 var(--space-md);
  }

  .services-headline {
    font-family: var(--font-display);
    font-size: clamp(1.75rem, 3.5vw, 2.5rem);
    font-weight: 700;
    line-height: 1.15;
    color: var(--text-primary);
    margin: var(--space-sm) 0 var(--space-xs);
    max-width: 38rem;
    letter-spacing: -0.01em;
  }

  .services-intro {
    font-family: var(--font-body);
    font-size: 1.0625rem;
    line-height: 1.65;
    color: var(--text-secondary, #6B7280);
    margin: 0 0 var(--space-lg);
    max-width: 40rem;
  }

  .services-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-md);
  }

  .service-card {
    background: var(--color-surface);
    border: 1px solid var(--color-arena);
    border-radius: var(--radius-card);
    padding: var(--space-lg);
    transition: transform var(--duration-base) var(--ease-spring), border-color var(--duration-base) var(--ease-spring), box-shadow var(--duration-base) var(--ease-spring);
  }

  .service-card:hover {
    transform: translateY(-4px);
    border-color: var(--color-jade);
    box-shadow: 0 12px 28px rgba(31, 36, 33, 0.08);
  }

  .service-card h3 {
    font-family: var(--font-display);
    font-size: 1.125rem;
    font-weight: 700;
    margin-bottom: var(--space-xs);
    color: var(--text-primary);
  }

  .service-card p {
    font-size: var(--text-small);
    color: var(--text-muted);
    line-height: 1.6;
    margin-bottom: var(--space-md);
  }

  .service-stat {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--color-jade-deep);
    background: var(--color-jade-soft);
    padding: 0.25rem 0.625rem;
    border-radius: var(--radius-pill);
  }

  /* Content feed */
  .content-feed {
    padding: var(--space-xl) 0;
  }

  .feed-inner {
    max-width: var(--max-width);
    margin: 0 auto;
    padding: 0 var(--space-md);
  }

  .feed-header {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    margin-bottom: var(--space-md);
  }

  .feed-header .section-label {
    margin-bottom: 0;
  }

  .feed-all {
    font-size: var(--text-small);
    font-weight: 500;
    color: var(--accent-text);
  }

  .bento-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-md);
  }

  /* Industries */
  .industries {
    padding: var(--space-xl) 0;
  }

  .industries-inner {
    max-width: var(--max-width);
    margin: 0 auto;
    padding: 0 var(--space-md);
  }

  .industries-label {
    font-family: var(--font-body);
    font-size: 10px;
    font-weight: 600;
    letter-spacing: 1px;
    text-transform: uppercase;
    color: var(--accent-text);
    margin-bottom: var(--space-md);
  }

  .industries-list {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-sm);
  }

  .industry-tag {
    font-size: var(--text-small);
    color: var(--text-body);
