---
import Base from '../layouts/Base.astro';
import ContentCard from '../components/ContentCard.astro';
import { fetchArticles } from '../lib/api';

const articles = await fetchArticles();
---

<Base
  title="Writing"
  description="Articles, questions, and takes on AI and automation for real businesses."
>
  <section class="writing-page">
    <div class="writing-inner">
      <header class="writing-header">
        <h1 data-en="Writing" data-es="Escritos">Writing</h1>
        <span class="writing-count">{articles.length} posts</span>
      </header>

      <div class="writing-controls">
        <div
          class="filter-group"
          role="tablist"
          aria-label="Filter by content type"
        >
          <button
            class="filter-btn active"
            data-filter="all"
            data-filter-index="0"
            role="tab"
            aria-selected="true"
            data-en="All"
            data-es="Todos">All</button
          >
          <button
            class="filter-btn"
            data-filter="article"
            data-filter-index="1"
            role="tab"
            aria-selected="false"
            data-en="Articles"
            data-es="Articulos">Articles</button
          >
          <button
            class="filter-btn"
            data-filter="deep_question"
            data-filter-index="2"
            role="tab"
            aria-selected="false"
            data-en="Questions"
            data-es="Preguntas">Questions</button
          >
          <button
            class="filter-btn"
            data-filter="unpopular_take"
            data-filter-index="3"
            role="tab"
            aria-selected="false"
            data-en="Takes"
            data-es="Opiniones">Takes</button
          >
          <button
            class="filter-btn"
            data-filter="image_quote"
            data-filter-index="4"
            role="tab"
            aria-selected="false"
            data-en="Thoughts"
            data-es="Pensamientos">Thoughts</button
          >
          <button
            class="filter-btn"
            data-filter="tip"
            data-filter-index="5"
            role="tab"
            aria-selected="false"
            data-en="Tips"
            data-es="Consejos">Tips</button
          >
        </div>

        <div class="search-box">
          <input
            type="search"
            id="article-search"
            aria-label="Search articles"
            placeholder="Search articles..."
            data-en-placeholder="Search articles..."
            data-es-placeholder="Buscar articulos..."
            autocomplete="off"
          />
        </div>
      </div>

      <div class="articles-grid" id="articles-grid">
        {
          articles.map((article, i) => (
            <div
              class="article-item"
              data-type={article.contentType}
              data-title={article.title.toLowerCase()}
              data-teaser={article.teaser.toLowerCase()}
              style={`--card-index: ${i % 12}`}
              hidden={i >= 12}
            >
              <ContentCard article={article} />
            </div>
          ))
        }
      </div>

      <p
        class="empty-state"
        id="empty-state"
        hidden
        data-en="No articles found."
        data-es="No se encontraron articulos."
      >
        No articles found.
      </p>

      <button
        class="load-more-btn"
        id="load-more"
        data-en="Load more"
        data-es="Cargar mas">Load more</button
      >
    </div>
  </section>
</Base>

<script>
  document.addEventListener('astro:page-load', () => {
    const grid = document.getElementById('articles-grid');
    if (!grid) return;

    const ITEMS_PER_PAGE = 12;
    let visibleCount = ITEMS_PER_PAGE;
    let activeFilter = 'all';
    let searchQuery = '';
    let prevFilterIndex = 0;

    function applyFilters() {
      const items = Array.from(
        grid!.querySelectorAll('.article-item')
      ) as HTMLElement[];
      let shown = 0;
      let totalMatches = 0;

      items.forEach((item) => {
        const type = item.dataset.type || '';
        const title = item.dataset.title || '';
        const teaser = item.dataset.teaser || '';

        const matchesFilter =
          activeFilter === 'all' || type === activeFilter;
        const matchesSearch =
          !searchQuery ||
          title.includes(searchQuery) ||
          teaser.includes(searchQuery);

        if (matchesFilter && matchesSearch) {
          totalMatches++;
          if (shown < visibleCount) {
            item.hidden = false;
            item.style.setProperty('--card-index', String(shown));
            shown++;
          } else {
            item.hidden = true;
          }
        } else {
          item.hidden = true;
        }
      });

      const emptyEl = document.getElementById('empty-state');
      const loadBtn = document.getElementById('load-more');

      if (emptyEl) emptyEl.hidden = totalMatches > 0;
      if (loadBtn) loadBtn.hidden = shown >= totalMatches;
    }

    function triggerCrossFade(newIndex: number) {
      const direction = newIndex > prevFilterIndex ? '-12px' : '12px';
      const items = grid!.querySelectorAll('.article-item:not([hidden])');
      items.forEach((item) => {
        const el = item as HTMLElement;
        el.style.setProperty('--slide-direction', direction);
        el.classList.remove('grid-cross-fade');
        void el.offsetWidth; // force reflow
        el.classList.add('grid-cross-fade');
      });
      prevFilterIndex = newIndex;
    }

    document.querySelectorAll('.filter-btn').forEach((btn) => {
      btn.addEventListener('click', () => {
        const newIndex = parseInt((btn as HTMLElement).dataset.filterIndex || '0', 10);
        document.querySelectorAll('.filter-btn').forEach((b) => {
          b.classList.remove('active');
          b.setAttribute('aria-selected', 'false');
        });
        btn.classList.add('active');
        btn.setAttribute('aria-selected', 'true');
        activeFilter =
          (btn as HTMLElement).dataset.filter || 'all';
        visibleCount = ITEMS_PER_PAGE;
        applyFilters();
        triggerCrossFade(newIndex);
      });
    });

    const searchInput = document.getElementById(
      'article-search'
    ) as HTMLInputElement;
    let debounceTimer: ReturnType<typeof setTimeout>;

    searchInput?.addEventListener('input', () => {
      clearTimeout(debounceTimer);
      debounceTimer = setTimeout(() => {
        searchQuery = searchInput.value.toLowerCase().trim();
        visibleCount = ITEMS_PER_PAGE;
        applyFilters();
      }, 300);
    });

    document
      .getElementById('load-more')
      ?.addEventListener('click', () => {
        visibleCount += ITEMS_PER_PAGE;
        applyFilters();
      });

    applyFilters();
  });
</script>

<style>
  .writing-page {
    padding: calc(var(--nav-height) + var(--space-xl)) 0 var(--space-xl);
  }

  .writing-inner {
    max-width: var(--max-width);
    margin: 0 auto;
    padding: 0 var(--space-md);
  }

  .writing-header {
    margin-bottom: var(--space-xl);
    display: flex;
    align-items: baseline;
    gap: var(--space-md);
  }

  .writing-header h1 {
    font-family: var(--font-display);
    font-size: var(--text-display);
  }

  .writing-count {
    font-family: var(--font-mono);
    font-size: var(--text-small);
    color: var(--text-muted);
  }

  .writing-controls {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: var(--space-md);
    margin-bottom: var(--space-lg);
    flex-wrap: wrap;
  }

  .filter-group {
    display: flex;
    gap: var(--space-xs);
  }

  .filter-btn {
    font-family: var(--font-body);
    font-size: var(--text-small);
    font-weight: 500;
    padding: 0.45rem 1rem;
    border: 1.5px solid var(--color-arena);
    background: transparent;
    color: var(--color-carbon-soft);
    border-radius: var(--radius-pill);
    cursor: pointer;
    transition: background var(--duration-base) var(--ease-spring), border-color var(--duration-base) var(--ease-spring), color var(--duration-base) var(--ease-spring);
  }

  .filter-btn:hover {
    border-color: var(--color-jade);
    color: var(--color-jade-deep);
  }

  .filter-btn.active {
    background: var(--color-jade);
    border-color: var(--color-jade);
    color: #FFFFFF;
  }

  .search-box input {
    font-family: var(--font-body);
    font-size: var(--text-small);
    padding: 0.55rem 0.9rem;
    border: 1.5px solid var(--color-arena);
    border-radius: 12px;
    background: var(--color-surface);
    color: var(--color-carbon);
    width: 240px;
    transition: border-color var(--duration-base) var(--ease-spring), box-shadow var(--duration-base) var(--ease-spring);
  }

  .search-box input:focus {
    outline: none;
    border-color: var(--color-jade);
    box-shadow: 0 0 0 3px rgba(14, 124, 102, 0.15);
  }

  .articles-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-md);
  }

  .empty-state {
    text-align: center;
    color: var(--color-carbon-soft);
    padding: var(--space-2xl) 0;
    font-family: var(--font-display);
    font-style: italic;
    font-size: 1.25rem;
    position: relative;
  }

  .empty-state::after {
    content: '';
    display: block;
    width: 8px;
    height: 8px;
    border-radius: var(--radius-pill);
    background: var(--color-jade);
    margin: 0.75rem auto 0;
    animation: emptyPulse 1.6s var(--ease-spring) infinite;
  }

  @keyframes emptyPulse {
    0%, 100% { opacity: 0.4; transform: scale(1); }
    50%      { opacity: 1;   transform: scale(1.3); }
  }

  .load-more-btn {
    display: block;
    margin: var(--space-xl) auto 0;
    font-family: var(--font-body);
    font-size: var(--text-small);
    font-weight: 500;
    padding: 0.65rem 1.75rem;
    border: 1.5px solid var(--color-arena);
    background: var(--color-surface);
    color: var(--color-carbon);
    border-radius: var(--radius-pill);
    cursor: pointer;
    transition: border-color var(--duration-base) var(--ease-spring), color var(--duration-base) var(--ease-spring), transform var(--duration-base) var(--ease-spring);
  }

  .load-more-btn:hover {
    border-color: var(--color-jade);
    color: var(--color-jade-deep);
    transform: translateY(-1px);
  }

  @media (max-width: 900px) {
    .articles-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 640px) {
    .articles-grid {
      grid-template-columns: 1fr;
    }

    .search-box input {
      width: 100%;
    }

    .writing-controls {
      flex-direction: column;
      align-items: stretch;
    }
  }
</style>
